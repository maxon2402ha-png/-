<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Color.Primary">#007ACC</Color>
    <Color x:Key="Color.PrimaryDark">#005A9C</Color>
    <Color x:Key="Color.PrimaryLight">#D9F0FF</Color>

    <Color x:Key="Color.Background">#F4F7F9</Color>
    <Color x:Key="Color.Surface">#FFFFFF</Color>
    <Color x:Key="Color.SurfaceAlt">#F0F3F5</Color>
    <Color x:Key="Color.Border">#E0E5EB</Color>

    <Color x:Key="Color.TextPrimary">#1E293B</Color>
    <Color x:Key="Color.TextSecondary">#64748B</Color>

    <Color x:Key="Color.Status.New">#22C55E</Color>
    <Color x:Key="Color.Status.InProgress">#FACC15</Color>
    <Color x:Key="Color.Status.Pending">#0EA5E9</Color>
    <Color x:Key="Color.Status.Overdue">#EF4444</Color>
    <SolidColorBrush x:Key="Brush.Primary" Color="{StaticResource Color.Primary}" />
    <SolidColorBrush x:Key="Brush.PrimaryDark" Color="{StaticResource Color.PrimaryDark}" />
    <SolidColorBrush x:Key="Brush.PrimaryLight" Color="{StaticResource Color.PrimaryLight}" />

    <SolidColorBrush x:Key="Brush.Background" Color="{StaticResource Color.Background}" />
    <SolidColorBrush x:Key="Brush.Surface" Color="{StaticResource Color.Surface}" />
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="{StaticResource Color.SurfaceAlt}" />
    <SolidColorBrush x:Key="Brush.Border" Color="{StaticResource Color.Border}" />

    <SolidColorBrush x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}" />
    <SolidColorBrush x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}" />
    <SolidColorBrush x:Key="Brush.Error" Color="{StaticResource Color.Status.Overdue}" />
</ResourceDictionary>