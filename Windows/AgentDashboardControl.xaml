<UserControl x:Class="КР_Ханников.Windows.AgentDashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI"
             Background="{DynamicResource Brush.Background}">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.05" Direction="270"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkloadProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="12"/>
                            <Border x:Name="PART_Track" CornerRadius="12"/>
                            <Border x:Name="PART_Indicator" CornerRadius="12" HorizontalAlignment="Left" Background="{TemplateBinding Foreground}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock x:Name="GreetingText" Text="Привет, Инженер!" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
            <TextBlock Text="Твоя сводка на сегодня. Следи за нагрузкой и SLA." FontSize="14" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="⚖️" FontSize="18" Margin="0,0,8,0"/>
                        <TextBlock Text="Уровень нагрузки (Workload Index)" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                    </StackPanel>

                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Свободен" HorizontalAlignment="Left" FontSize="12" Foreground="{DynamicResource Brush.TextMuted}"/>
                        <TextBlock Text="Максимум" HorizontalAlignment="Right" FontSize="12" Foreground="{DynamicResource Brush.TextMuted}"/>
                    </Grid>

                    <ProgressBar x:Name="WorkloadProgress" Minimum="0" Maximum="20" Value="0" Style="{StaticResource WorkloadProgressBar}" Foreground="#10B981"/>

                    <Grid Margin="0,8,0,0">
                        <TextBlock x:Name="WorkloadPointsText" Text="0 / 20 баллов" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="WorkloadStatusText" Text="Всё отлично" FontSize="13" Foreground="#10B981" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Соблюдение SLA" FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock x:Name="SlaText" Text="100%" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource Brush.Primary}" HorizontalAlignment="Center"/>
                    <TextBlock Text="за последние 7 дней" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource CardStyle}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Среднее время (ART)" FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock x:Name="ArtText" Text="0.0" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        <TextBlock Text=" ч." FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextSecondary}" VerticalAlignment="Bottom" Margin="4,0,0,6"/>
                    </StackPanel>
                    <TextBlock Text="на решение 1 заявки" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="24,20" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
                    <TextBlock Text="Мои задачи в работе" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                </Border>

                <DataGrid x:Name="MyTicketsGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="Transparent" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{DynamicResource Brush.Divider}" RowHeight="50" Margin="2">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="16,12"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Divider}"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80"/>
                        <DataGridTextColumn Header="ПРИОРИТЕТ" Binding="{Binding Priority}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Priority}" Value="Critical">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Danger}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Priority}" Value="High">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Warning}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="ТЕМА ЗАЯВКИ" Binding="{Binding Title}" Width="*"/>
                        <DataGridTextColumn Header="ДЕДЛАЙН (SLA)" Binding="{Binding DueAt, StringFormat=dd.MM.yyyy HH:mm}" Width="160">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>