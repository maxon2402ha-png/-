<UserControl x:Class="КР_Ханников.Windows.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:core="clr-namespace:КР_Ханников.Core"
             xmlns:converters="clr-namespace:КР_Ханников.Converters"
             mc:Ignorable="d"
             d:DesignHeight="1200" d:DesignWidth="1200"
             FontFamily="Segoe UI"
             Background="{DynamicResource Brush.Background}">

    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>

        <Geometry x:Key="Icon.Ticket">M22 10V6c0-1.1-.9-2-2-2H4c-1.1 0-1.99.9-1.99 2v4c1.1 0 1.99.9 1.99 2s-.89 2-2 2v4c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2v-4c-1.1 0-2-.9-2-2s.9-2 2-2zm-2-1.46c-1.19.69-2 1.99-2 3.46s.81 2.77 2 3.46V18H4v-2.54c1.19-.69 2-1.99 2-3.46s-.81-2.77-2-3.46V6h16v2.54zM11 15h2v2h-2zm0-4h2v2h-2zm0-4h2v2h-2z</Geometry>
        <Geometry x:Key="Icon.Lightning">M13 2.05v3.03c3.39.49 6 3.39 6 6.92 0 .9-.22 1.75-.61 2.5l2.16 2.16C21.47 15.31 22 13.71 22 12c0-5.16-3.95-9.39-9-9.95zM4.93 4.93l2.16 2.16C6.22 7.84 6 8.9 6 10c0 3.31 2.69 6 6 6 1.1 0 2.16-.32 3.01-.88l2.16 2.16C15.82 18.33 14.04 19 12 19c-4.97 0-9-4.03-9-9 0-2.04.67-3.82 1.93-5.07zM11 2v4l3-3-3-3zm0 18v4l3-3-3-3z</Geometry>
        <Geometry x:Key="Icon.Clock">M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z</Geometry>
        <Geometry x:Key="Icon.CheckCircle">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z</Geometry>
        <Geometry x:Key="Icon.Chart">M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z</Geometry>
        <Geometry x:Key="Icon.Percent">M18.5 3.5L5.5 20.5l2 2L20.5 5.5l-2-2zM7 9c1.66 0 3-1.34 3-3S8.66 3 7 3 4 4.34 4 6s1.34 3 3 3zm0-4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm10 14c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3zm0 4c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z</Geometry>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Border}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Background}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="CompactComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2" Opacity="0.04" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="MinHeight" Value="100"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.PrimaryLight}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="MinHeight" Value="48"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.PrimaryLight}"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}" Padding="32,24" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Мониторинг и аналитика" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                    <TextBlock Text="Ключевые показатели эффективности и статистика по обращениям" FontSize="14" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LastUpdatedText}" FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" Margin="0,0,24,0"/>
                    <StackPanel Margin="0,0,16,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentUserName}" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Right" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        <TextBlock Text="{Binding CurrentUserRole}" FontSize="12" Foreground="{DynamicResource Brush.TextSecondary}" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <Border Width="44" Height="44" CornerRadius="22" Background="{DynamicResource Brush.PrimaryLight}">
                        <TextBlock Text="📊" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,24,32,32">

                <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Период" Style="{StaticResource FilterLabel}"/>
                                <StackPanel Orientation="Horizontal">
                                    <DatePicker x:Name="FromDatePicker" Width="130"/>
                                    <TextBlock Text="—" Margin="10,0" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextMuted}"/>
                                    <DatePicker x:Name="ToDatePicker" Width="130"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="7 дней" Style="{StaticResource SecondaryButton}" Click="Quick7_Click" Padding="12,0"/>
                                    <Button Content="30 дней" Style="{StaticResource SecondaryButton}" Click="Quick30_Click" Padding="12,0" Margin="10,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Статус" Style="{StaticResource FilterLabel}"/>
                                <ComboBox x:Name="StatusFilter" Width="140" SelectionChanged="Filter_SelectionChanged">
                                    <ComboBoxItem Content="Все" IsSelected="True"/>
                                    <ComboBoxItem Content="Open"/>
                                    <ComboBoxItem Content="In Progress"/>
                                    <ComboBoxItem Content="Closed"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="6">
                                <TextBlock Text="Категория" Style="{StaticResource FilterLabel}"/>
                                <ComboBox x:Name="CategoryFilter" Width="150" SelectionChanged="Filter_SelectionChanged"/>
                            </StackPanel>

                            <Button Grid.Column="8" Content="⚙ Настройки" Style="{StaticResource SecondaryButton}" Click="OpenSettings_Click" VerticalAlignment="Bottom"/>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Приоритет" Style="{StaticResource FilterLabel}"/>
                                <ComboBox x:Name="PriorityFilter" Width="140" SelectionChanged="Filter_SelectionChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Исполнитель" Style="{StaticResource FilterLabel}"/>
                                <ComboBox x:Name="AssigneeFilter" Width="180" SelectionChanged="Filter_SelectionChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Группировка" Style="{StaticResource FilterLabel}"/>
                                <ComboBox x:Name="GroupByCombo" Width="130" SelectionChanged="Filter_SelectionChanged">
                                    <ComboBoxItem Content="Дни" IsSelected="True"/>
                                    <ComboBoxItem Content="Недели"/>
                                    <ComboBoxItem Content="Месяцы"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Bottom">
                                <Button Content="Обновить" Style="{StaticResource PrimaryButton}" Click="ApplyFilters_Click" MinWidth="110"/>
                                <Button Content="Сбросить" Style="{StaticResource GhostButton}" Click="ResetFilters_Click" Margin="10,0,0,0"/>
                                <Button Content="CSV" Style="{StaticResource SecondaryButton}" Click="ExportCsv_Click" Padding="14,0" Margin="16,0,0,0"/>
                                <Button Content="PDF" Style="{StaticResource SecondaryButton}" Click="ExportPdf_Click" Padding="14,0" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <UniformGrid x:Name="KpiSection" Columns="6" Margin="0,0,0,24">
                    <Border Style="{StaticResource KpiCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Path Data="{StaticResource Icon.Ticket}" Fill="{DynamicResource Brush.TextSecondary}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="Всего" Style="{StaticResource KpiLabel}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding KpiTotal}" Style="{StaticResource KpiValue}" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Path Data="{StaticResource Icon.Lightning}" Fill="#F59E0B" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="Открыто" Style="{StaticResource KpiLabel}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding KpiOpen}" Style="{StaticResource KpiValue}" Foreground="#F59E0B"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Path Data="{StaticResource Icon.Clock}" Fill="#3B82F6" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="В работе" Style="{StaticResource KpiLabel}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding KpiInProgress}" Style="{StaticResource KpiValue}" Foreground="#3B82F6"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Path Data="{StaticResource Icon.CheckCircle}" Fill="#10B981" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="Закрыто" Style="{StaticResource KpiLabel}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding KpiClosed}" Style="{StaticResource KpiValue}" Foreground="#10B981"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Path Data="{StaticResource Icon.Chart}" Fill="{DynamicResource Brush.Accent}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="Ср. время (ч)" Style="{StaticResource KpiLabel}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding KpiAvgResolutionText}" Style="{StaticResource KpiValue}" Foreground="{DynamicResource Brush.Accent}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCard}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Path Data="{StaticResource Icon.Percent}" Fill="{DynamicResource Brush.TextSecondary}" Width="14" Height="14" Stretch="Uniform" VerticalAlignment="Center"/>
                                <TextBlock Text="Решено (%)" Style="{StaticResource KpiLabel}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{Binding KpiResolvedPercentText}" Style="{StaticResource KpiValue}" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid x:Name="ChartsSection" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="450"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,20">
                                <TextBlock Text="Динамика обращений" Style="{StaticResource SectionTitle}"/>
                                <ComboBox x:Name="SortDaysCombo" Style="{StaticResource CompactComboBox}" Width="150" HorizontalAlignment="Right" SelectionChanged="Sort_SelectionChanged">
                                    <ComboBoxItem Content="По дате (возр.)" IsSelected="True"/>
                                    <ComboBoxItem Content="По дате (убыв.)"/>
                                </ComboBox>
                            </Grid>
                            <lvc:CartesianChart x:Name="ChartDynamics" Series="{Binding SeriesTicketsByDay}" Height="280" LegendLocation="None">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Период" Labels="{Binding LabelsDays}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="1" StrokeThickness="0"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="Кол-во" LabelFormatter="{Binding CountFormatter}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Stroke="{DynamicResource Brush.Divider}"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <DockPanel>
                            <TextBlock Text="Категории" DockPanel.Dock="Top" Style="{StaticResource SectionTitle}" Margin="0,0,0,16"/>
                            <ComboBox x:Name="CategorySortCombo" DockPanel.Dock="Top" Style="{StaticResource CompactComboBox}" Margin="0,0,0,16" SelectionChanged="Sort_SelectionChanged">
                                <ComboBoxItem Content="По количеству" IsSelected="True"/>
                                <ComboBoxItem Content="По имени (А-Я)"/>
                            </ComboBox>
                            <lvc:PieChart x:Name="ChartCategories" Series="{Binding SeriesCategories}" LegendLocation="Bottom" Height="220" Hoverable="True" InnerRadius="45"/>
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="450"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,20">
                                <TextBlock Text="Распределение по сотрудникам" Style="{StaticResource SectionTitle}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <ComboBox x:Name="AssigneeSortCombo" Style="{StaticResource CompactComboBox}" Width="140" Margin="0,0,10,0" SelectionChanged="Sort_SelectionChanged">
                                        <ComboBoxItem Content="По нагрузке" IsSelected="True"/>
                                        <ComboBoxItem Content="По имени"/>
                                    </ComboBox>
                                    <ComboBox x:Name="TopAssigneesCombo" Style="{StaticResource CompactComboBox}" Width="80" SelectionChanged="Sort_SelectionChanged">
                                        <ComboBoxItem Content="Все" IsSelected="True"/>
                                        <ComboBoxItem Content="Топ 5"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                            <lvc:CartesianChart x:Name="ChartAssignees" Series="{Binding SeriesByAssignee}" Height="240" LegendLocation="None">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Тикеты" LabelFormatter="{Binding CountFormatter}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Labels="{Binding LabelsAssignees}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="1" StrokeThickness="0"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <DockPanel>
                            <TextBlock Text="Приоритеты" DockPanel.Dock="Top" Style="{StaticResource SectionTitle}" Margin="0,0,0,16"/>
                            <ComboBox x:Name="PrioritySortCombo" DockPanel.Dock="Top" Style="{StaticResource CompactComboBox}" Margin="0,0,0,16" SelectionChanged="Sort_SelectionChanged">
                                <ComboBoxItem Content="По количеству" IsSelected="True"/>
                                <ComboBoxItem Content="По важности"/>
                            </ComboBox>
                            <lvc:PieChart x:Name="ChartPriorities" Series="{Binding SeriesPriorities}" LegendLocation="Right" Height="200" Hoverable="True" InnerRadius="45"/>
                        </DockPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                    <DockPanel>
                        <TextBlock Text="Матрица компетенций и нагрузки (Performance Matrix)" DockPanel.Dock="Top" Style="{StaticResource SectionTitle}" Margin="0,0,0,20"/>

                        <DataGrid x:Name="PerformanceMatrixGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  HorizontalGridLinesBrush="{DynamicResource Brush.Border}"
                                  VerticalGridLinesBrush="Transparent"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  RowHeaderWidth="0"
                                  CanUserResizeRows="False"
                                  SelectionMode="Single"
                                  RowHeight="48"
                                  ColumnHeaderHeight="42">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ИНЖЕНЕР" Binding="{Binding Name}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="В РАБОТЕ" Binding="{Binding ActiveTickets}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="НАГРУЗКА (ИНДЕКС)" Width="160">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                                                <TextBlock Text="{Binding WorkloadPoints}" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                                <TextBlock Text=" / 20 баллов" Foreground="{DynamicResource Brush.TextMuted}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTemplateColumn Header="СТАТУС" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="10,4" HorizontalAlignment="Left" Margin="12,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource Brush.SuccessLight}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsOverloaded}" Value="True">
                                                                <Setter Property="Background" Value="#FEE2E2"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding WorkloadStatus}" FontSize="12" FontWeight="Bold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource Brush.Success}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsOverloaded}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Danger}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsWarning}" Value="True">
                                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Warning}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="SLA (%)" Binding="{Binding SlaText}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="ART (ч)" Binding="{Binding ArtText}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border x:Name="TableSection" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock Text="Детализация данных" DockPanel.Dock="Top" Style="{StaticResource SectionTitle}" Margin="0,0,0,20"/>

                        <DataGrid x:Name="DashboardTicketsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  HorizontalGridLinesBrush="{DynamicResource Brush.Border}"
                                  VerticalGridLinesBrush="Transparent"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  RowHeaderWidth="0"
                                  CanUserResizeRows="False"
                                  CanUserAddRows="False"
                                  SelectionMode="Single"
                                  MaxHeight="500"
                                  RowHeight="48"
                                  ColumnHeaderHeight="42">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Тема" Binding="{Binding Title}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="FontSize" Value="14"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Статус" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}" CornerRadius="12" Padding="10,4" HorizontalAlignment="Left" Margin="12,0">
                                                <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Приоритет" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Priority}" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}" Padding="12,0" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Исполнитель" Binding="{Binding Assignee.User.Username, TargetNullValue=—}" Width="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Создано" Binding="{Binding CreatedAt, StringFormat=dd.MM.yy}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Срок" Binding="{Binding DueAt, StringFormat=dd.MM.yy, TargetNullValue=—}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Danger}"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>