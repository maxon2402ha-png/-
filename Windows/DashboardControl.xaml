<UserControl x:Class="КР_Ханников.Windows.DashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             xmlns:core="clr-namespace:КР_Ханников.Core"
             xmlns:converters="clr-namespace:КР_Ханников.Converters"
             mc:Ignorable="d"
             d:DesignHeight="1000" d:DesignWidth="1200"
             FontFamily="Segoe UI"
             Background="{DynamicResource Brush.Background}">

    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Background}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="CompactComboBox" TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2" Opacity="0.04" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="MinHeight" Value="110"/>
        </Style>

        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="MinHeight" Value="48"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.PrimaryLight}"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}" Padding="32,24" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Мониторинг и аналитика" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                    <TextBlock Text="Ключевые показатели эффективности и статистика по обращениям" FontSize="14" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding LastUpdatedText}" FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" Margin="0,0,24,0"/>
                    <StackPanel Margin="0,0,16,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding CurrentUserName}" FontWeight="SemiBold" FontSize="14" HorizontalAlignment="Right" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        <TextBlock Text="{Binding CurrentUserRole}" FontSize="12" Foreground="{DynamicResource Brush.TextSecondary}" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <Border Width="44" Height="44" CornerRadius="22" Background="{DynamicResource Brush.PrimaryLight}">
                        <TextBlock Text="📊" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,24,32,32">

                <Border Style="{StaticResource Card}" Margin="0,0,0,24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="20"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Период" Style="{StaticResource FilterLabel}"/>
                                <StackPanel Orientation="Horizontal">
                                    <DatePicker x:Name="FromDatePicker" Width="130"/>
                                    <TextBlock Text="—" Margin="10,0" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextMuted}"/>
                                    <DatePicker x:Name="ToDatePicker" Width="130"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="7 дней" Style="{StaticResource SecondaryButton}" Click="Quick7_Click" Padding="12,0"/>
                                    <Button Content="30 дней" Style="{StaticResource SecondaryButton}" Click="Quick30_Click" Padding="12,0" Margin="10,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Статус" Style="{StaticResource FilterLabel}"/>
                                <ComboBox x:Name="StatusFilter" Width="140" SelectionChanged="Filter_SelectionChanged">
                                    <ComboBoxItem Content="Все" IsSelected="True"/>
                                    <ComboBoxItem Content="Open"/>
                                    <ComboBoxItem Content="In Progress"/>
                                    <ComboBoxItem Content="Closed"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="6">
                                <TextBlock Text="Категория" Style="{StaticResource FilterLabel}"/>
                                <ComboBox x:Name="CategoryFilter" Width="150" SelectionChanged="Filter_SelectionChanged"/>
                            </StackPanel>

                            <Button Grid.Column="8" Content="⚙ Настройки" Style="{StaticResource SecondaryButton}" Click="OpenSettings_Click" VerticalAlignment="Bottom"/>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="24"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Приоритет" Style="{StaticResource FilterLabel}"/>
                                <ComboBox x:Name="PriorityFilter" Width="140" SelectionChanged="Filter_SelectionChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Исполнитель" Style="{StaticResource FilterLabel}"/>
                                <ComboBox x:Name="AssigneeFilter" Width="180" SelectionChanged="Filter_SelectionChanged"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="Группировка" Style="{StaticResource FilterLabel}"/>
                                <ComboBox x:Name="GroupByCombo" Width="130" SelectionChanged="Filter_SelectionChanged">
                                    <ComboBoxItem Content="Дни" IsSelected="True"/>
                                    <ComboBoxItem Content="Недели"/>
                                    <ComboBoxItem Content="Месяцы"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Bottom">
                                <Button Content="Обновить" Style="{StaticResource PrimaryButton}" Click="ApplyFilters_Click" MinWidth="110"/>
                                <Button Content="Сбросить" Style="{StaticResource GhostButton}" Click="ResetFilters_Click" Margin="10,0,0,0"/>
                                <Button Content="CSV" Style="{StaticResource SecondaryButton}" Click="ExportCsv_Click" Padding="14,0" Margin="16,0,0,0"/>
                                <Button Content="PDF" Style="{StaticResource SecondaryButton}" Click="ExportPdf_Click" Padding="14,0" Margin="10,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <UniformGrid x:Name="KpiSection" Columns="6" Margin="0,0,0,24">
                    <Border Style="{StaticResource KpiCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Всего" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Text="{Binding KpiTotal}" Style="{StaticResource KpiValue}" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Открыто" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Text="{Binding KpiOpen}" Style="{StaticResource KpiValue}" Foreground="{DynamicResource Brush.Status.Open}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="В работе" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Text="{Binding KpiInProgress}" Style="{StaticResource KpiValue}" Foreground="{DynamicResource Brush.Status.InProgress}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Закрыто" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Text="{Binding KpiClosed}" Style="{StaticResource KpiValue}" Foreground="{DynamicResource Brush.Status.Closed}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Ср. время" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Text="{Binding KpiAvgResolutionText}" Style="{StaticResource KpiValue}" FontSize="24" Foreground="{DynamicResource Brush.Accent}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource KpiCard}">
                        <StackPanel>
                            <TextBlock Text="Решено (%)" Style="{StaticResource KpiLabel}"/>
                            <TextBlock Text="{Binding KpiResolvedPercentText}" Style="{StaticResource KpiValue}" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid x:Name="ChartsSection" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="450"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,20">
                                <TextBlock Text="Динамика обращений" Style="{StaticResource SectionTitle}"/>
                                <ComboBox x:Name="SortDaysCombo" Style="{StaticResource CompactComboBox}" Width="150" HorizontalAlignment="Right" SelectionChanged="Sort_SelectionChanged">
                                    <ComboBoxItem Content="По дате (возр.)" IsSelected="True"/>
                                    <ComboBoxItem Content="По дате (убыв.)"/>
                                </ComboBox>
                            </Grid>
                            <lvc:CartesianChart x:Name="ChartDynamics" Series="{Binding SeriesTicketsByDay}" Height="280" LegendLocation="None">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Период" Labels="{Binding LabelsDays}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="1" StrokeThickness="0"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Title="Кол-во" LabelFormatter="{Binding CountFormatter}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Stroke="{DynamicResource Brush.Divider}"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <DockPanel>
                            <TextBlock Text="Категории" DockPanel.Dock="Top" Style="{StaticResource SectionTitle}" Margin="0,0,0,16"/>
                            <ComboBox x:Name="CategorySortCombo" DockPanel.Dock="Top" Style="{StaticResource CompactComboBox}" Margin="0,0,0,16" SelectionChanged="Sort_SelectionChanged">
                                <ComboBoxItem Content="По количеству" IsSelected="True"/>
                                <ComboBoxItem Content="По имени (А-Я)"/>
                            </ComboBox>
                            <lvc:PieChart x:Name="ChartCategories" Series="{Binding SeriesCategories}" LegendLocation="Bottom" Height="220" Hoverable="True" InnerRadius="45"/>
                        </DockPanel>
                    </Border>
                </Grid>

                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="450"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="340"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <DockPanel>
                            <Grid DockPanel.Dock="Top" Margin="0,0,0,20">
                                <TextBlock Text="Загрузка сотрудников" Style="{StaticResource SectionTitle}"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <ComboBox x:Name="AssigneeSortCombo" Style="{StaticResource CompactComboBox}" Width="140" Margin="0,0,10,0" SelectionChanged="Sort_SelectionChanged">
                                        <ComboBoxItem Content="По нагрузке" IsSelected="True"/>
                                        <ComboBoxItem Content="По имени"/>
                                    </ComboBox>
                                    <ComboBox x:Name="TopAssigneesCombo" Style="{StaticResource CompactComboBox}" Width="80" SelectionChanged="Sort_SelectionChanged">
                                        <ComboBoxItem Content="Все" IsSelected="True"/>
                                        <ComboBoxItem Content="Топ 5"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                            <lvc:CartesianChart x:Name="ChartAssignees" Series="{Binding SeriesByAssignee}" Height="240" LegendLocation="None">
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis Title="Тикеты" LabelFormatter="{Binding CountFormatter}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11"/>
                                </lvc:CartesianChart.AxisX>
                                <lvc:CartesianChart.AxisY>
                                    <lvc:Axis Labels="{Binding LabelsAssignees}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="1" StrokeThickness="0"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisY>
                            </lvc:CartesianChart>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <DockPanel>
                            <TextBlock Text="Приоритеты" DockPanel.Dock="Top" Style="{StaticResource SectionTitle}" Margin="0,0,0,16"/>
                            <ComboBox x:Name="PrioritySortCombo" DockPanel.Dock="Top" Style="{StaticResource CompactComboBox}" Margin="0,0,0,16" SelectionChanged="Sort_SelectionChanged">
                                <ComboBoxItem Content="По количеству" IsSelected="True"/>
                                <ComboBoxItem Content="По важности"/>
                            </ComboBox>
                            <lvc:PieChart x:Name="ChartPriorities" Series="{Binding SeriesPriorities}" LegendLocation="Right" Height="200" Hoverable="True" InnerRadius="45"/>
                        </DockPanel>
                    </Border>
                </Grid>

                <Border x:Name="TableSection" Style="{StaticResource Card}">
                    <DockPanel>
                        <TextBlock Text="Детализация данных" DockPanel.Dock="Top" Style="{StaticResource SectionTitle}" Margin="0,0,0,20"/>

                        <DataGrid x:Name="DashboardTicketsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="None"
                                  HorizontalGridLinesBrush="{DynamicResource Brush.Border}"
                                  VerticalGridLinesBrush="Transparent"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  RowHeaderWidth="0"
                                  CanUserResizeRows="False"
                                  CanUserAddRows="False"
                                  SelectionMode="Single"
                                  MaxHeight="500"
                                  RowHeight="48"
                                  ColumnHeaderHeight="42">

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Тема" Binding="{Binding Title}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="FontSize" Value="14"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Статус" Width="130">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}" CornerRadius="12" Padding="10,4" HorizontalAlignment="Left" Margin="12,0">
                                                <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="FontWeight" Value="Medium"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Приоритет" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Priority}" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}" Padding="12,0" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Исполнитель" Binding="{Binding Assignee.User.Username, TargetNullValue=—}" Width="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Создано" Binding="{Binding CreatedAt, StringFormat=dd.MM.yy}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Срок" Binding="{Binding DueAt, StringFormat=dd.MM.yy, TargetNullValue=—}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                                            <Setter Property="Padding" Value="12,0"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Danger}"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>