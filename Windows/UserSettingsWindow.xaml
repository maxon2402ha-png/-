<Window x:Class="КР_Ханников.Windows.UserSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Персонализация"
        Height="450"
        Width="520"
        MinHeight="400"
        MinWidth="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI"
        Background="{DynamicResource Brush.Background}">

    <Window.Resources>
        <Geometry x:Key="Icon.Dashboard">M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z</Geometry>
        <Geometry x:Key="Icon.Refresh">M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z</Geometry>
        <Geometry x:Key="Icon.Timer">M15 1H9v2h6V1zm-4 13h2V8h-2v6zm8.03-6.61l1.42-1.42c-.43-.51-.9-.99-1.41-1.41l-1.42 1.42C16.07 4.74 14.12 4 12 4c-4.97 0-9 4.03-9 9s4.03 9 9 9 9-4.03 9-9c0-2.12-.74-4.07-1.97-5.61zM12 20c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z</Geometry>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Background}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0" VerticalAlignment="Center"/>
                            <Border x:Name="track" Grid.Column="1" Width="40" Height="22" CornerRadius="11" Background="{DynamicResource Brush.Border}" Margin="12,0,0,0">
                                <Border x:Name="thumb" Width="18" Height="18" CornerRadius="9" Background="White" HorizontalAlignment="Left" Margin="2,0,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="4" Opacity="0.2" ShadowDepth="1"/>
                                    </Border.Effect>
                                </Border>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="{DynamicResource Brush.Primary}"/>
                                <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsSection" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="24"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.Primary}"/>
        </Style>

        <Storyboard x:Key="WindowFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}" Padding="20,16" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="40"
                        Height="40"
                        CornerRadius="10"
                        Background="#F3E8FF"
                        Margin="0,0,14,0">
                    <Path Data="{StaticResource Icon.Dashboard}"
                          Fill="#9333EA"
                          Width="20" Height="20"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Настройки дашборда" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource Brush.TextPrimary}"/>
                    <TextBlock Text="Настройте отображение аналитики" 
                               FontSize="12" 
                               Foreground="{DynamicResource Brush.TextSecondary}" 
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20,16">
            <StackPanel>

                <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Path Data="{StaticResource Icon.Dashboard}"
                                  Fill="{DynamicResource Brush.TextSecondary}"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  Margin="0,0,8,0"/>
                            <TextBlock Text="Видимость блоков"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Показывать KPI" 
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                                <TextBlock Text="Сводные цифры в верхней части дашборда" 
                                           FontSize="11"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ShowKpiCheck" 
                                      Grid.Column="1"
                                      Style="{StaticResource ToggleSwitch}"
                                      IsChecked="True"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Показывать графики" 
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                                <TextBlock Text="Диаграммы и визуализации данных" 
                                           FontSize="11"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ShowChartsCheck" 
                                      Grid.Column="1"
                                      Style="{StaticResource ToggleSwitch}"
                                      IsChecked="True"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Показывать таблицу" 
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                                <TextBlock Text="Детальная таблица с данными" 
                                           FontSize="11"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="ShowTableCheck" 
                                      Grid.Column="1"
                                      Style="{StaticResource ToggleSwitch}"
                                      IsChecked="True"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Path Data="{StaticResource Icon.Timer}"
                                  Fill="{DynamicResource Brush.TextSecondary}"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  Margin="0,0,8,0"/>
                            <TextBlock Text="Период по умолчанию"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </StackPanel>

                        <ComboBox x:Name="PeriodCombo">
                            <ComboBoxItem Content="Последние 7 дней" Tag="7" IsSelected="True"/>
                            <ComboBoxItem Content="Последние 30 дней" Tag="30"/>
                            <ComboBoxItem Content="Последние 90 дней" Tag="90"/>
                            <ComboBoxItem Content="За год" Tag="365"/>
                        </ComboBox>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsSection}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                            <Path Data="{StaticResource Icon.Refresh}"
                                  Fill="{DynamicResource Brush.TextSecondary}"
                                  Width="16" Height="16"
                                  Stretch="Uniform"
                                  Margin="0,0,8,0"/>
                            <TextBlock Text="Автообновление"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </StackPanel>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Автоматическое обновление" 
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                                <TextBlock Text="Обновлять данные автоматически" 
                                           FontSize="11"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                            <CheckBox x:Name="AutoRefreshCheck" 
                                      Grid.Column="1"
                                      Style="{StaticResource ToggleSwitch}"
                                      IsChecked="True"
                                      Checked="AutoRefreshCheck_Changed"
                                      Unchecked="AutoRefreshCheck_Changed"/>
                        </Grid>

                        <StackPanel x:Name="RefreshIntervalPanel">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Интервал обновления"
                                           FontSize="12"
                                           Foreground="{DynamicResource Brush.TextSecondary}"/>
                                <TextBlock x:Name="RefreshIntervalText"
                                           Text="30 сек"
                                           FontSize="12"
                                           FontWeight="Medium"
                                           Foreground="{DynamicResource Brush.TextPrimary}"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                            <Slider x:Name="RefreshSlider"
                                    Minimum="10"
                                    Maximum="120"
                                    Value="30"
                                    TickFrequency="10"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="RefreshSlider_ValueChanged"/>
                            <Grid Margin="0,4,0,0">
                                <TextBlock Text="10 сек"
                                           FontSize="10"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           HorizontalAlignment="Left"/>
                                <TextBlock Text="2 мин"
                                           FontSize="10"
                                           Foreground="{DynamicResource Brush.TextMuted}"
                                           HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource Brush.Surface}" Padding="20,14" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Сбросить"
                        Click="Reset_Click"
                        Style="{StaticResource SecondaryButton}"
                        Foreground="{DynamicResource Brush.Danger}"
                        BorderBrush="#FECACA"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Отмена" 
                            Click="Cancel_Click" 
                            Style="{StaticResource SecondaryButton}"
                            IsCancel="True"/>
                    <Button Content="Сохранить" 
                            Click="Save_Click" 
                            Style="{StaticResource PrimaryButton}"
                            IsDefault="True"
                            Margin="10,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>