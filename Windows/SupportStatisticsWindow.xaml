<Window x:Class="КР_Ханников.Windows.SupportStatisticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Статистика сотрудников"
        Height="650" Width="950"
        MinHeight="550" MinWidth="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI"
        Background="{DynamicResource Brush.Background}">

    <Window.Resources>
        <Geometry x:Key="Icon.Star">M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z</Geometry>
        <Geometry x:Key="Icon.Trophy">M19 5h-2V3H7v2H5c-1.1 0-2 .9-2 2v1c0 2.55 1.92 4.63 4.39 4.94.63 1.5 1.98 2.63 3.61 2.96V19H7v2h10v-2h-3.61c1.63-.33 2.98-1.46 3.61-2.96 2.47-.31 4.39-2.39 4.39-4.94v-1c0-1.1-.9-2-2-2zm-4-2h2v2h-2V3zm-8 2h2v2H7V5zM5 6h2v1h-2V6zm14 1h-2V6h2v1zM12 16c-1.66 0-3-1.34-3-3s1.34-3 3-3 3 1.34 3 3-1.34 3-3 3z</Geometry>
        <Geometry x:Key="Icon.Users">M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z</Geometry>
        <Geometry x:Key="Icon.Chart">M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z</Geometry>
        <Geometry x:Key="Icon.Download">M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z</Geometry>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" Opacity="0.04" ShadowDepth="2" Direction="270" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Background}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CellCenter" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="CellLeft" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}" Padding="24,20" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10" Background="{DynamicResource Brush.SuccessLight}" Margin="0,0,16,0">
                    <Path Data="{StaticResource Icon.Trophy}" Fill="{DynamicResource Brush.Warning}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Статистика эффективности" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                    <TextBlock Text="Рейтинг и активность сотрудников поддержки" FontSize="12" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Click="Export_Click" ToolTip="Экспорт в Excel">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon.Download}" Fill="{DynamicResource Brush.TextSecondary}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="Экспорт"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="28" Height="28" CornerRadius="6" Background="{DynamicResource Brush.SurfaceAlt}">
                            <Path Data="{StaticResource Icon.Star}" Fill="{DynamicResource Brush.Warning}" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="AvgRatingText" Text="0.0" Style="{StaticResource KpiValue}"/>
                    <TextBlock Text="Средний рейтинг" Style="{StaticResource KpiLabel}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource KpiCard}" Margin="8,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="28" Height="28" CornerRadius="6" Background="{DynamicResource Brush.PrimaryLight}">
                            <Path Data="{StaticResource Icon.Chart}" Fill="{DynamicResource Brush.Primary}" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="TotalFeedbackText" Text="0" Style="{StaticResource KpiValue}"/>
                    <TextBlock Text="Всего отзывов" Style="{StaticResource KpiLabel}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource KpiCard}" Margin="8,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="28" Height="28" CornerRadius="6" Background="#F3E8FF">
                            <Path Data="{StaticResource Icon.Users}" Fill="#9333EA" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="TotalEmployeesText" Text="0" Style="{StaticResource KpiValue}"/>
                    <TextBlock Text="Сотрудников" Style="{StaticResource KpiLabel}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Style="{StaticResource KpiCard}" Margin="8,0,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Border Width="28" Height="28" CornerRadius="6" Background="{DynamicResource Brush.SuccessLight}">
                            <Path Data="{StaticResource Icon.Trophy}" Fill="{DynamicResource Brush.Success}" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="TopEmployeeText" Text="—" Style="{StaticResource KpiValue}" FontSize="18" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="Лидер рейтинга" Style="{StaticResource KpiLabel}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="24,0,24,16" Background="{DynamicResource Brush.Surface}" CornerRadius="8" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource Brush.SurfaceAlt}" Padding="16,12" CornerRadius="8,8,0,0" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
                    <TextBlock Text="Детальный рейтинг" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Brush.TextPrimary}"/>
                </Border>

                <DataGrid x:Name="StatsGrid" 
                          Grid.Row="1"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          HeadersVisibility="Column" 
                          GridLinesVisibility="Horizontal" 
                          HorizontalGridLinesBrush="{DynamicResource Brush.Border}" 
                          VerticalGridLinesBrush="Transparent"
                          Background="Transparent" 
                          BorderThickness="0" 
                          RowHeaderWidth="0"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          RowHeight="48">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="Padding" Value="12,10"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}" BorderThickness="0" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Brush.PrimaryLight}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="#" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="24" Height="24" CornerRadius="12" Background="{DynamicResource Brush.SurfaceAlt}" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Position}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextSecondary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Сотрудник" Binding="{Binding Name}" Width="*" ElementStyle="{StaticResource CellLeft}"/>

                        <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="150" ElementStyle="{StaticResource CellLeft}"/>

                        <DataGridTemplateColumn Header="Рейтинг" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid Margin="12,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                                            <TextBlock Text="★" Foreground="{DynamicResource Brush.Warning}" FontSize="12" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding AverageRating, StringFormat=N1}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                        </StackPanel>
                                        <Grid Grid.Column="1" Height="6" VerticalAlignment="Center">
                                            <Border Background="{DynamicResource Brush.Border}" CornerRadius="3"/>
                                            <Border Background="{DynamicResource Brush.Warning}" CornerRadius="3" HorizontalAlignment="Left" Width="{Binding RatingPercent}"/>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Отзывы" Binding="{Binding FeedbackCount}" Width="100" ElementStyle="{StaticResource CellCenter}"/>

                        <DataGridTextColumn Header="Решено" Binding="{Binding ResolvedCount}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource CellCenter}">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Success}"/>
                                    <Setter Property="FontWeight" Value="Medium"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="3" Background="{DynamicResource Brush.Surface}" Padding="24,14" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Данные обновляются автоматически" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" VerticalAlignment="Center"/>

                <Button Grid.Column="1" Content="Закрыть" Click="Close_Click" Style="{StaticResource SecondaryButton}" MinWidth="90" IsCancel="True"/>
            </Grid>
        </Border>
    </Grid>
</Window>