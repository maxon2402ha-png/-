<Window x:Class="КР_Ханников.Windows.AnalyticsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Аналитика: KPI и нагрузка"
        Height="720" Width="1080"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI"
        Background="{DynamicResource Brush.Background}">

    <Window.Resources>
        <Geometry x:Key="Icon.Chart">M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z</Geometry>
        <Geometry x:Key="Icon.Download">M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z</Geometry>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="16,14"/>
        </Style>

        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CellCenter" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="CellLeft" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="GridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="RowHeight" Value="46"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ШАПКА -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}" Padding="24,20" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10" Background="{DynamicResource Brush.PrimaryLight}" Margin="0,0,16,0">
                    <Path Data="{StaticResource Icon.Chart}" Fill="{DynamicResource Brush.Primary}" Width="22" Height="22" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Аналитика нагрузки и KPI" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                    <TextBlock Text="Мониторинг эффективности сотрудников технической поддержки" FontSize="12" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Click="Export_Click" ToolTip="Экспорт текущей вкладки в CSV">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon.Download}" Fill="{DynamicResource Brush.TextSecondary}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="Экспорт CSV"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ПАНЕЛЬ ПЕРИОДА -->
        <Border Grid.Row="1" Background="{DynamicResource Brush.Surface}" Padding="24,12" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Период:" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="13" Margin="0,0,10,0"/>
                <DatePicker x:Name="FromDatePicker" Width="130" VerticalContentAlignment="Center"/>
                <TextBlock Text="—" VerticalAlignment="Center" Margin="8,0" Foreground="{DynamicResource Brush.TextSecondary}"/>
                <DatePicker x:Name="ToDatePicker" Width="130" VerticalContentAlignment="Center"/>
                <Button Content="Применить" Style="{StaticResource SecondaryButton}" Click="Apply_Click" Margin="12,0,0,0" MinWidth="100"/>
                <Button Content="30 дней" Style="{StaticResource SecondaryButton}" Click="Quick30_Click" Margin="8,0,0,0"/>
                <Button Content="90 дней" Style="{StaticResource SecondaryButton}" Click="Quick90_Click" Margin="8,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- ВКЛАДКИ -->
        <TabControl Grid.Row="2" Margin="24,16" Background="Transparent" BorderThickness="0">

            <!-- ВКЛАДКА 1: KPI СОТРУДНИКОВ -->
            <TabItem Header="KPI сотрудников">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Сводные KPI-карточки -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock x:Name="KpiSlaText" Text="0%" Style="{StaticResource KpiValue}"/>
                                <TextBlock Text="SLA-compliance" Style="{StaticResource KpiLabel}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource KpiCard}" Margin="8,0">
                            <StackPanel>
                                <TextBlock x:Name="KpiFrtText" Text="—" Style="{StaticResource KpiValue}"/>
                                <TextBlock Text="Ср. время ответа" Style="{StaticResource KpiLabel}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource KpiCard}" Margin="8,0">
                            <StackPanel>
                                <TextBlock x:Name="KpiResolutionText" Text="—" Style="{StaticResource KpiValue}"/>
                                <TextBlock Text="Ср. время решения" Style="{StaticResource KpiLabel}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Style="{StaticResource KpiCard}" Margin="8,0">
                            <StackPanel>
                                <TextBlock x:Name="KpiResolvedText" Text="0" Style="{StaticResource KpiValue}"/>
                                <TextBlock Text="Решено тикетов" Style="{StaticResource KpiLabel}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="4" Style="{StaticResource KpiCard}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock x:Name="KpiOverdueText" Text="0%" Style="{StaticResource KpiValue}"/>
                                <TextBlock Text="Доля просрочки" Style="{StaticResource KpiLabel}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Таблица KPI по сотрудникам -->
                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{DynamicResource Brush.SurfaceAlt}" Padding="16,12" CornerRadius="8,8,0,0" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
                                <TextBlock Text="KPI по сотрудникам поддержки" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Brush.TextPrimary}"/>
                            </Border>
                            <DataGrid x:Name="KpiGrid" Grid.Row="1" Style="{StaticResource GridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Сотрудник" Binding="{Binding Name}" Width="*" ElementStyle="{StaticResource CellLeft}"/>
                                    <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="130" ElementStyle="{StaticResource CellLeft}"/>
                                    <DataGridTextColumn Header="Тикетов" Binding="{Binding TotalTickets}" Width="90" ElementStyle="{StaticResource CellCenter}"/>
                                    <DataGridTextColumn Header="Решено" Binding="{Binding ResolvedTickets}" Width="90" ElementStyle="{StaticResource CellCenter}"/>
                                    <DataGridTextColumn Header="SLA, %" Binding="{Binding SlaCompliancePercent, StringFormat=N1}" Width="90" ElementStyle="{StaticResource CellCenter}"/>
                                    <DataGridTextColumn Header="Ответ, ч" Binding="{Binding AvgFirstResponseHours, StringFormat=N1}" Width="100" ElementStyle="{StaticResource CellCenter}"/>
                                    <DataGridTextColumn Header="Решение, ч" Binding="{Binding AvgResolutionHours, StringFormat=N1}" Width="110" ElementStyle="{StaticResource CellCenter}"/>
                                    <DataGridTextColumn Header="Просрочка, %" Binding="{Binding OverdueRate, StringFormat=N1}" Width="120" ElementStyle="{StaticResource CellCenter}"/>
                                    <DataGridTextColumn Header="Оценка" Binding="{Binding AvgRating, StringFormat=N1}" Width="90" ElementStyle="{StaticResource CellCenter}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ВКЛАДКА 2: НАГРУЗКА ОПЕРАТОРОВ -->
            <TabItem Header="Нагрузка операторов">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Сводка по нагрузке -->
                    <Grid Grid.Row="0" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock x:Name="WlAvgText" Text="0%" Style="{StaticResource KpiValue}"/>
                                <TextBlock Text="Средняя загрузка" Style="{StaticResource KpiLabel}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource KpiCard}" Margin="8,0">
                            <StackPanel>
                                <TextBlock x:Name="WlOverloadedText" Text="0" Style="{StaticResource KpiValue}" Foreground="{DynamicResource Brush.Danger}"/>
                                <TextBlock Text="Перегружено" Style="{StaticResource KpiLabel}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" Style="{StaticResource KpiCard}" Margin="8,0">
                            <StackPanel>
                                <TextBlock x:Name="WlActiveText" Text="0" Style="{StaticResource KpiValue}"/>
                                <TextBlock Text="Активных тикетов" Style="{StaticResource KpiLabel}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" Style="{StaticResource KpiCard}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock x:Name="WlEmployeesText" Text="0" Style="{StaticResource KpiValue}"/>
                                <TextBlock Text="Операторов" Style="{StaticResource KpiLabel}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Таблица нагрузки -->
                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{DynamicResource Brush.SurfaceAlt}" Padding="16,12" CornerRadius="8,8,0,0" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
                                <TextBlock Text="Взвешенная нагрузка операторов" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Brush.TextPrimary}"/>
                            </Border>
                            <DataGrid x:Name="WorkloadGrid" Grid.Row="1" Style="{StaticResource GridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Оператор" Binding="{Binding Name}" Width="*" ElementStyle="{StaticResource CellLeft}"/>
                                    <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="130" ElementStyle="{StaticResource CellLeft}"/>
                                    <DataGridTextColumn Header="Активных" Binding="{Binding ActiveTickets}" Width="100" ElementStyle="{StaticResource CellCenter}"/>
                                    <DataGridTextColumn Header="Критич." Binding="{Binding CriticalCount}" Width="90" ElementStyle="{StaticResource CellCenter}"/>
                                    <DataGridTextColumn Header="Вес. нагрузка" Binding="{Binding WeightedLoad}" Width="120" ElementStyle="{StaticResource CellCenter}"/>
                                    <DataGridTextColumn Header="Лимит" Binding="{Binding MaxActiveTickets}" Width="90" ElementStyle="{StaticResource CellCenter}"/>

                                    <!-- Колонка загрузки с цветным индикатором -->
                                    <DataGridTemplateColumn Header="Загрузка" Width="220">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid Margin="12,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="55"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding LoadPercent, StringFormat={}{0:N0}%}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                                    <Grid Grid.Column="1" Height="6" VerticalAlignment="Center">
                                                        <Border Background="{DynamicResource Brush.Border}" CornerRadius="3"/>
                                                        <Border x:Name="Bar" CornerRadius="3" HorizontalAlignment="Left" Width="{Binding LoadPercent}" Background="{DynamicResource Brush.Success}"/>
                                                    </Grid>
                                                </Grid>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding Level}" Value="High">
                                                        <Setter TargetName="Bar" Property="Background" Value="{DynamicResource Brush.Warning}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Level}" Value="Overloaded">
                                                        <Setter TargetName="Bar" Property="Background" Value="{DynamicResource Brush.Danger}"/>
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>

                                    <DataGridTextColumn Header="Статус" Binding="{Binding LevelText}" Width="150" ElementStyle="{StaticResource CellLeft}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ПОДВАЛ -->
        <Border Grid.Row="3" Background="{DynamicResource Brush.Surface}" Padding="24,14" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Grid.Column="0" Text="Готово" Foreground="{DynamicResource Brush.TextMuted}" FontSize="12" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Закрыть" Click="Close_Click" Style="{StaticResource SecondaryButton}" MinWidth="90" IsCancel="True"/>
            </Grid>
        </Border>
    </Grid>
</Window>
