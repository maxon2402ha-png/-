<Window x:Class="КР_Ханников.Windows.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Уведомление" 
        Height="90" 
        Width="340"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True" 
        ShowInTaskbar="False" 
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">

    <Window.Resources>
        <Geometry x:Key="Icon.Bell">M12 22c1.1 0 2-.9 2-2h-4c0 1.1.9 2 2 2zm6-6v-5c0-3.07-1.63-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.64 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z</Geometry>
        <Geometry x:Key="Icon.Check">M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z</Geometry>
        <Geometry x:Key="Icon.Warning">M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z</Geometry>
        <Geometry x:Key="Icon.Error">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z</Geometry>
        <Geometry x:Key="Icon.Info">M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z</Geometry>
        <Geometry x:Key="Icon.Close">M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z</Geometry>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <Path x:Name="icon"
                                  Data="{StaticResource Icon.Close}"
                                  Fill="{TemplateBinding Foreground}"
                                  Width="10" Height="10"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                <Setter TargetName="icon" Property="Fill" Value="{DynamicResource Brush.TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="SlideIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                             From="0" To="1" 
                             Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                             From="360" To="0" 
                             Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="FadeOut" Completed="FadeOut_Completed">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                             From="1" To="0" 
                             Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardBorder"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" 
                             From="0" To="360" 
                             Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="ProgressAnimation">
            <DoubleAnimation Storyboard.TargetName="ProgressBar"
                             Storyboard.TargetProperty="Width"
                             From="320" To="0"
                             Duration="0:0:5"/>
        </Storyboard>
    </Window.Resources>

    <Grid Margin="8">
        <Border x:Name="CardBorder" 
                Background="{DynamicResource Brush.Surface}" 
                CornerRadius="8"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                Cursor="Hand"
                MouseLeftButtonUp="Toast_Click">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" 
                                  ShadowDepth="4" 
                                  Opacity="0.15" 
                                  Color="Black"
                                  Direction="270"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform/>
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="3"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="IconBorder" 
                            Grid.Column="0"
                            Width="44"
                            Background="{DynamicResource Brush.Primary}"
                            CornerRadius="7,0,0,0">
                        <Path x:Name="IconPath"
                              Data="{StaticResource Icon.Bell}"
                              Fill="White"
                              Width="20" Height="20"
                              Stretch="Uniform"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" 
                                Margin="12,10" 
                                VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText" 
                                   Text="Уведомление" 
                                   FontWeight="SemiBold" 
                                   FontSize="13" 
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="MessageText" 
                                   Text="Текст уведомления" 
                                   FontSize="12" 
                                   Foreground="{DynamicResource Brush.TextSecondary}" 
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,3,0,0"
                                   MaxWidth="220"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Style="{StaticResource CloseButton}"
                            Click="Close_Click"
                            Margin="0,8,8,0"
                            VerticalAlignment="Top"/>
                </Grid>

                <Border Grid.Row="1" 
                        Background="{DynamicResource Brush.SurfaceAlt}"
                        CornerRadius="0,0,7,7">
                    <Border x:Name="ProgressBar"
                            Background="{DynamicResource Brush.Primary}"
                            CornerRadius="0,0,0,7"
                            HorizontalAlignment="Left"
                            Width="320"
                            Opacity="0.6"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>