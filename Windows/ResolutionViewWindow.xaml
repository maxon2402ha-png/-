<Window x:Class="КР_Ханников.Windows.ResolutionViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Просмотр решения"
        Height="450"
        Width="580"
        MinHeight="350"
        MinWidth="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI"
        Background="{DynamicResource Brush.Background}">

    <Window.Resources>
        <Geometry x:Key="Icon.Check">M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z</Geometry>
        <Geometry x:Key="Icon.Copy">M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z</Geometry>
        <Geometry x:Key="Icon.User">M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z</Geometry>
        <Geometry x:Key="Icon.Calendar">M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z</Geometry>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Background}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="WindowFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                             From="0" To="1" 
                             Duration="0:0:0.15"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{DynamicResource Brush.Surface}" 
                Padding="20,16" 
                BorderBrush="{DynamicResource Brush.Border}" 
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="40"
                        Height="40"
                        CornerRadius="10"
                        Background="{DynamicResource Brush.SuccessLight}"
                        Margin="0,0,14,0">
                    <Path Data="{StaticResource Icon.Check}"
                          Fill="{DynamicResource Brush.Success}"
                          Width="20" Height="20"
                          Stretch="Uniform"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Решение по тикету" 
                                   FontSize="17" 
                                   FontWeight="Bold" 
                                   Foreground="{DynamicResource Brush.TextPrimary}"/>
                        <Border x:Name="TicketIdBadge"
                                Background="{DynamicResource Brush.SurfaceAlt}"
                                CornerRadius="4"
                                Padding="8,2"
                                Margin="10,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="TicketIdText" 
                                       Text="#—" 
                                       FontSize="12" 
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource Brush.Primary}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="Тикет решён и закрыт" 
                               FontSize="12" 
                               Foreground="{DynamicResource Brush.TextSecondary}" 
                               Margin="0,2,0,0"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Style="{StaticResource IconButton}"
                        Click="CopyResolution_Click"
                        ToolTip="Копировать текст решения">
                    <Path Data="{StaticResource Icon.Copy}"
                          Fill="{DynamicResource Brush.TextSecondary}"
                          Width="16" Height="16"
                          Stretch="Uniform"/>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,16">
            <Border Background="{DynamicResource Brush.Surface}" 
                    CornerRadius="8" 
                    BorderBrush="{DynamicResource Brush.Border}" 
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="6" Opacity="0.05" ShadowDepth="2" Direction="270" Color="Black"/>
                </Border.Effect>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" 
                            Background="{DynamicResource Brush.SurfaceAlt}" 
                            Padding="16,12"
                            BorderBrush="{DynamicResource Brush.Border}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="8,8,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Path Data="{StaticResource Icon.User}"
                                      Fill="{DynamicResource Brush.TextMuted}"
                                      Width="14" Height="14"
                                      Stretch="Uniform"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Решил" 
                                               FontSize="10" 
                                               Foreground="{DynamicResource Brush.TextMuted}"/>
                                    <TextBlock x:Name="ResolvedByText"
                                               Text="—"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource Brush.TextPrimary}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" 
                                        Orientation="Horizontal" 
                                        HorizontalAlignment="Right">
                                <Path Data="{StaticResource Icon.Calendar}"
                                      Fill="{DynamicResource Brush.TextMuted}"
                                      Width="14" Height="14"
                                      Stretch="Uniform"
                                      Margin="0,0,8,0"
                                      VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="Дата решения" 
                                               FontSize="10" 
                                               Foreground="{DynamicResource Brush.TextMuted}"/>
                                    <TextBlock x:Name="ResolvedAtText"
                                               Text="—"
                                               FontSize="12"
                                               FontWeight="Medium"
                                               Foreground="{DynamicResource Brush.TextPrimary}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ResolutionTextBlock"
                                   Text="{Binding ResolutionText}" 
                                   TextWrapping="Wrap" 
                                   Foreground="{DynamicResource Brush.TextPrimary}" 
                                   FontSize="14"
                                   LineHeight="22"
                                   Padding="16"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" 
                Background="{DynamicResource Brush.Surface}" 
                Padding="20,14" 
                BorderBrush="{DynamicResource Brush.Border}" 
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" 
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Width="8" Height="8" 
                            CornerRadius="4" 
                            Background="{DynamicResource Brush.Success}"
                            Margin="0,0,8,0"/>
                    <TextBlock Text="Тикет успешно решён"
                               Foreground="{DynamicResource Brush.Success}"
                               FontSize="12"
                               FontWeight="Medium"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="Закрыть" 
                        Style="{StaticResource SecondaryButton}" 
                        Click="Close_Click"
                        IsCancel="True"/>
            </Grid>
        </Border>
    </Grid>
</Window>