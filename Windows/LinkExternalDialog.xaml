<Window x:Class="КР_Ханников.Windows.LinkExternalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Связать с внешней системой"
        Height="530"
        Width="450"
        MinHeight="350"
        MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="{DynamicResource Brush.Background}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Border}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Background}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SystemCard" TargetType="RadioButton">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0" 
                                                  VerticalAlignment="Center"/>
                                <Ellipse x:Name="checkMark" 
                                         Grid.Column="2"
                                         Width="18" Height="18"
                                         Stroke="{DynamicResource Brush.Border}"
                                         StrokeThickness="2"
                                         Fill="Transparent"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.Primary}"/>
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryLight}"/>
                                <Setter TargetName="checkMark" Property="Fill" Value="{DynamicResource Brush.Primary}"/>
                                <Setter TargetName="checkMark" Property="Stroke" Value="{DynamicResource Brush.Primary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Storyboard x:Key="WindowFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" 
                             From="0" To="1" 
                             Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" 
                             From="0.95" To="1" 
                             Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" 
                             From="0.95" To="1" 
                             Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Window.RenderTransform>
        <ScaleTransform CenterX="225" CenterY="190"/>
    </Window.RenderTransform>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{DynamicResource Brush.Surface}" 
                Padding="20,16" 
                BorderBrush="{DynamicResource Brush.Border}" 
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="36"
                        Height="36"
                        CornerRadius="8"
                        Background="{DynamicResource Brush.PrimaryLight}"
                        Margin="0,0,14,0">
                    <TextBlock Text="🔗"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="16"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Связать с внешней системой" 
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Brush.TextPrimary}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock Text="Тикет: " 
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.TextSecondary}"/>
                        <TextBlock x:Name="TicketInfoText" 
                                   Text="#— Загрузка..." 
                                   FontSize="12"
                                   Foreground="{DynamicResource Brush.TextPrimary}"
                                   FontWeight="Medium"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" 
                Background="{DynamicResource Brush.Surface}" 
                Margin="16"
                CornerRadius="8"
                Padding="20"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Выберите систему" Style="{StaticResource FieldLabel}"/>

                <StackPanel x:Name="SystemsPanel">
                    <RadioButton x:Name="JiraRadio" 
                                 Style="{StaticResource SystemCard}" 
                                 GroupName="System"
                                 IsChecked="True">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔵" FontSize="16" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Jira" 
                                           FontWeight="SemiBold" 
                                           FontSize="13"
                                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                                <TextBlock Text="Atlassian Issue Tracker" 
                                           FontSize="11"
                                           Foreground="{DynamicResource Brush.TextSecondary}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="TrelloRadio" 
                                 Style="{StaticResource SystemCard}" 
                                 GroupName="System">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="16" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Trello" 
                                           FontWeight="SemiBold" 
                                           FontSize="13"
                                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                                <TextBlock Text="Kanban доски" 
                                           FontSize="11"
                                           Foreground="{DynamicResource Brush.TextSecondary}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="BugzillaRadio" 
                                 Style="{StaticResource SystemCard}" 
                                 GroupName="System">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🐛" FontSize="16" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Bugzilla" 
                                           FontWeight="SemiBold" 
                                           FontSize="13"
                                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                                <TextBlock Text="Bug Tracking" 
                                           FontSize="11"
                                           Foreground="{DynamicResource Brush.TextSecondary}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton x:Name="MantisRadio" 
                                 Style="{StaticResource SystemCard}" 
                                 GroupName="System"
                                 Margin="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🪲" FontSize="16" Margin="0,0,10,0"/>
                            <StackPanel>
                                <TextBlock Text="Mantis" 
                                           FontWeight="SemiBold" 
                                           FontSize="13"
                                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                                <TextBlock Text="MantisBT Tracker" 
                                           FontSize="11"
                                           Foreground="{DynamicResource Brush.TextSecondary}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" 
                Background="{DynamicResource Brush.Surface}" 
                Padding="20,14" 
                BorderBrush="{DynamicResource Brush.Border}" 
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Настройки проекта берутся из конфигурации"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           FontSize="11"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal">
                    <Button Content="Отмена" 
                            Style="{StaticResource SecondaryButton}" 
                            Click="Cancel_Click"
                            MinWidth="90"
                            IsCancel="True"/>
                    <Button x:Name="LinkButton"
                            Content="🔗 Связать" 
                            Style="{StaticResource PrimaryButton}" 
                            Click="Ok_Click"
                            MinWidth="120"
                            Margin="10,0,0,0"
                            IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>