<Window x:Class="КР_Ханников.Windows.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация"
        Height="650"
        Width="950"
        MinHeight="600"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Geometry x:Key="Icon.Check">M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z</Geometry>
        <Geometry x:Key="Icon.Close">M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z</Geometry>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Border}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Background}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                            <Path Data="{StaticResource Icon.Close}" Fill="{TemplateBinding Foreground}" Width="12" Height="12" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Danger}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.Primary}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.Primary}"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Storyboard x:Key="WindowFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border Background="{DynamicResource Brush.Surface}" CornerRadius="12" BorderThickness="1" BorderBrush="{DynamicResource Brush.Border}">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.25"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="11,0,0,11">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{DynamicResource Color.Primary}" Offset="0.0"/>
                        <GradientStop Color="{DynamicResource Color.PrimaryDark}" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid Margin="32">
                    <StackPanel VerticalAlignment="Center">
                        <Border Width="64" Height="64" Background="White" CornerRadius="16" HorizontalAlignment="Left" Margin="0,0,0,24">
                            <TextBlock Text="📝" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Регистрация" Foreground="White" FontSize="24" FontWeight="Bold" LineHeight="36"/>
                        <TextBlock Text="нового пользователя" Foreground="{DynamicResource Brush.PrimaryLight}" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

                        <TextBlock Text="Создайте аккаунт для доступа к системе управления заявками." Foreground="#E0E7FF" FontSize="14" TextWrapping="Wrap" Opacity="0.9" LineHeight="24" Margin="0,0,0,32"/>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="20" Height="20" CornerRadius="10" Background="{DynamicResource Brush.Success}" Margin="0,0,10,0">
                                    <Path Data="{StaticResource Icon.Check}" Fill="White" Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Быстрая регистрация" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Border Width="20" Height="20" CornerRadius="10" Background="{DynamicResource Brush.Success}" Margin="0,0,10,0">
                                    <Path Data="{StaticResource Icon.Check}" Fill="White" Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Личный кабинет" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="20" Height="20" CornerRadius="10" Background="{DynamicResource Brush.Success}" Margin="0,0,10,0">
                                    <Path Data="{StaticResource Icon.Check}" Fill="White" Width="10" Height="10" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Отслеживание заявок" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="© 2025 Service Desk Platform" VerticalAlignment="Bottom" Foreground="{DynamicResource Brush.PrimaryLight}" FontSize="11" Opacity="0.7"/>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="32,24" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent" Cursor="SizeAll">
                    <Grid>
                        <TextBlock Text="Создание аккаунта" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}" VerticalAlignment="Center"/>
                        <Button Style="{StaticResource CloseButton}" HorizontalAlignment="Right" Click="Cancel_Click"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="32,0,32,32">
                    <StackPanel>
                        <Border x:Name="ErrorBorder" Background="{DynamicResource Brush.Danger}" Opacity="0.1" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,16" Visibility="Collapsed"/>
                        <StackPanel x:Name="ErrorPanel" Orientation="Horizontal" Margin="0,-44,0,16" Visibility="Collapsed" VerticalAlignment="Center">
                            <TextBlock Text="⚠️" Margin="12,0,8,0" Foreground="{DynamicResource Brush.Danger}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ErrorText" Text="Ошибка валидации" Foreground="{DynamicResource Brush.Danger}" FontSize="13" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="Имя и Фамилия" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="FullNameBox" Margin="0,0,0,20" TabIndex="0"/>

                        <TextBlock Text="Логин" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="UsernameBox" Margin="0,0,0,20" TabIndex="2"/>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="PasswordBox" PasswordChanged="PasswordBox_PasswordChanged" TabIndex="3"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Повторите пароль" Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="ConfirmPasswordBox" PasswordChanged="ConfirmPasswordBox_PasswordChanged" TabIndex="4"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="StrengthBar1" Grid.Column="0" Height="4" Background="{DynamicResource Brush.Border}" CornerRadius="2" Margin="0,0,4,0"/>
                            <Border x:Name="StrengthBar2" Grid.Column="1" Height="4" Background="{DynamicResource Brush.Border}" CornerRadius="2" Margin="0,0,4,0"/>
                            <Border x:Name="StrengthBar3" Grid.Column="2" Height="4" Background="{DynamicResource Brush.Border}" CornerRadius="2" Margin="0,0,4,0"/>
                            <Border x:Name="StrengthBar4" Grid.Column="3" Height="4" Background="{DynamicResource Brush.Border}" CornerRadius="2"/>
                        </Grid>

                        <Grid Margin="0,0,0,24">
                            <TextBlock x:Name="PasswordStrengthText" Text="" FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" HorizontalAlignment="Left"/>

                            <StackPanel x:Name="PasswordMatchPanel" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                                <Border x:Name="PasswordMatchIcon" Width="16" Height="16" CornerRadius="8" Background="{DynamicResource Brush.Success}" Margin="0,0,6,0">
                                    <Path Data="{StaticResource Icon.Check}" Fill="White" Width="8" Height="8" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="PasswordMatchText" Text="Пароли совпадают" Foreground="{DynamicResource Brush.Success}" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Button x:Name="RegisterButton" Content="Зарегистрироваться" Click="Register_Click" IsDefault="True" Style="{StaticResource PrimaryButton}" Margin="0,0,0,12" TabIndex="5"/>
                        <Button Content="Уже есть аккаунт? Войти" Click="Cancel_Click" Style="{StaticResource SecondaryButton}" TabIndex="6"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>