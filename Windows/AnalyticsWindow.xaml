<UserControl x:Class="КР_Ханников.Windows.AnalyticsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d"
             d:DesignHeight="900" d:DesignWidth="1200"
             FontFamily="Segoe UI"
             Background="{DynamicResource Brush.Background}">

    <UserControl.Resources>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Background}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2" Opacity="0.04" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="20,16"/>
            <Setter Property="MinHeight" Value="100"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.PrimaryLight}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        </Style>

        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="MinHeight" Value="48"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.PrimaryLight}"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="GridBase" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="ColumnHeaderHeight" Value="40"/>
        </Style>

        <Style x:Key="CellCenter" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ШАПКА (в стиле DashboardControl) -->
        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}" Padding="32,24" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Аналитика нагрузки и KPI" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                    <TextBlock Text="Мониторинг эффективности и анализ загрузки сотрудников технической поддержки" FontSize="14" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="Готово" FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Border Width="44" Height="44" CornerRadius="22" Background="{DynamicResource Brush.PrimaryLight}">
                        <TextBlock Text="📈" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- КОНТЕНТ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,24,32,32">

                <!-- ПАНЕЛЬ ПЕРИОДА -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,24" Padding="24,18">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="Период с" Style="{StaticResource FilterLabel}"/>
                            <DatePicker x:Name="FromDatePicker" Width="150"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,0">
                            <TextBlock Text="по" Style="{StaticResource FilterLabel}"/>
                            <DatePicker x:Name="ToDatePicker" Width="150"/>
                        </StackPanel>
                        <Button Content="Применить" Style="{StaticResource PrimaryButton}" Click="Apply_Click" MinWidth="110" VerticalAlignment="Bottom" Margin="0,0,8,0"/>
                        <Button Content="30 дней" Style="{StaticResource SecondaryButton}" Click="Quick30_Click" VerticalAlignment="Bottom" Margin="0,0,8,0"/>
                        <Button Content="90 дней" Style="{StaticResource SecondaryButton}" Click="Quick90_Click" VerticalAlignment="Bottom"/>
                        <Button Content="Экспорт CSV" Style="{StaticResource SecondaryButton}" Click="Export_Click" VerticalAlignment="Bottom" Margin="16,0,0,0" MinWidth="120"/>
                    </StackPanel>
                </Border>

                <!-- ===================== БЛОК KPI ===================== -->
                <TextBlock Text="KPI сотрудников поддержки" Style="{StaticResource SectionTitle}" Margin="0,0,0,16"/>

                <!-- Сводные KPI-карточки -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource KpiCard}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="KpiSlaText" Text="0%" Style="{StaticResource KpiValue}"/>
                            <TextBlock Text="SLA-compliance" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource KpiCard}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="KpiFrtText" Text="—" Style="{StaticResource KpiValue}"/>
                            <TextBlock Text="Ср. время ответа" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource KpiCard}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="KpiResolutionText" Text="—" Style="{StaticResource KpiValue}"/>
                            <TextBlock Text="Ср. время решения" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="6" Style="{StaticResource KpiCard}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="KpiResolvedText" Text="0" Style="{StaticResource KpiValue}"/>
                            <TextBlock Text="Решено тикетов" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="8" Style="{StaticResource KpiCard}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="KpiOverdueText" Text="0%" Style="{StaticResource KpiValue}"/>
                            <TextBlock Text="Доля просрочки" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Таблица KPI по сотрудникам -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,32" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="24,18" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Детализация по сотрудникам" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </Border>
                        <DataGrid x:Name="KpiGrid" Grid.Row="1" Style="{StaticResource GridBase}" Margin="8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Сотрудник" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="130"/>
                                <DataGridTextColumn Header="Тикетов" Binding="{Binding TotalTickets}" Width="90" ElementStyle="{StaticResource CellCenter}"/>
                                <DataGridTextColumn Header="Решено" Binding="{Binding ResolvedTickets}" Width="90" ElementStyle="{StaticResource CellCenter}"/>
                                <DataGridTextColumn Header="SLA, %" Binding="{Binding SlaCompliancePercent, StringFormat=N1}" Width="90" ElementStyle="{StaticResource CellCenter}"/>
                                <DataGridTextColumn Header="Ответ, ч" Binding="{Binding AvgFirstResponseHours, StringFormat=N1}" Width="100" ElementStyle="{StaticResource CellCenter}"/>
                                <DataGridTextColumn Header="Решение, ч" Binding="{Binding AvgResolutionHours, StringFormat=N1}" Width="110" ElementStyle="{StaticResource CellCenter}"/>
                                <DataGridTextColumn Header="Просрочка, %" Binding="{Binding OverdueRate, StringFormat=N1}" Width="120" ElementStyle="{StaticResource CellCenter}"/>
                                <DataGridTextColumn Header="Оценка" Binding="{Binding AvgRating, StringFormat=N1}" Width="90" ElementStyle="{StaticResource CellCenter}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- ===================== БЛОК НАГРУЗКИ ===================== -->
                <TextBlock Text="Взвешенная нагрузка операторов" Style="{StaticResource SectionTitle}" Margin="0,0,0,16"/>

                <!-- Сводка по нагрузке -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource KpiCard}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="WlAvgText" Text="0%" Style="{StaticResource KpiValue}"/>
                            <TextBlock Text="Средняя загрузка" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource KpiCard}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="WlOverloadedText" Text="0" Style="{StaticResource KpiValue}" Foreground="{DynamicResource Brush.Danger}"/>
                            <TextBlock Text="Перегружено" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource KpiCard}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="WlActiveText" Text="0" Style="{StaticResource KpiValue}"/>
                            <TextBlock Text="Активных тикетов" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="6" Style="{StaticResource KpiCard}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="WlEmployeesText" Text="0" Style="{StaticResource KpiValue}"/>
                            <TextBlock Text="Операторов" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Таблица нагрузки -->
                <Border Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="24,18" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
                            <TextBlock Text="Текущая нагрузка по операторам" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </Border>
                        <DataGrid x:Name="WorkloadGrid" Grid.Row="1" Style="{StaticResource GridBase}" Margin="8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Оператор" Binding="{Binding Name}" Width="*"/>
                                <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="130"/>
                                <DataGridTextColumn Header="Активных" Binding="{Binding ActiveTickets}" Width="100" ElementStyle="{StaticResource CellCenter}"/>
                                <DataGridTextColumn Header="Критич." Binding="{Binding CriticalCount}" Width="90" ElementStyle="{StaticResource CellCenter}"/>
                                <DataGridTextColumn Header="Вес. нагрузка" Binding="{Binding WeightedLoad}" Width="120" ElementStyle="{StaticResource CellCenter}"/>
                                <DataGridTextColumn Header="Лимит" Binding="{Binding MaxActiveTickets}" Width="90" ElementStyle="{StaticResource CellCenter}"/>

                                <DataGridTemplateColumn Header="Загрузка" Width="240">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,12,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="55"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding LoadPercent, StringFormat={}{0:N0}%}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                                <Grid Grid.Column="1" Height="8" VerticalAlignment="Center">
                                                    <Border Background="{DynamicResource Brush.Border}" CornerRadius="4"/>
                                                    <Border x:Name="Bar" CornerRadius="4" HorizontalAlignment="Left" Width="{Binding LoadPercent}" Background="{DynamicResource Brush.Success}"/>
                                                </Grid>
                                            </Grid>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding Level}" Value="High">
                                                    <Setter TargetName="Bar" Property="Background" Value="{DynamicResource Brush.Warning}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Level}" Value="Overloaded">
                                                    <Setter TargetName="Bar" Property="Background" Value="{DynamicResource Brush.Danger}"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Статус" Binding="{Binding LevelText}" Width="150"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- ============ БЛОК РЕКОМЕНДАЦИЙ ПО ПЕРЕРАСПРЕДЕЛЕНИЮ ============ -->
                <TextBlock Text="Рекомендации по балансировке нагрузки" Style="{StaticResource SectionTitle}" Margin="0,32,0,16"/>

                <Border Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Padding="24,18" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
                            <TextBlock x:Name="RebalanceHeaderText" Text="Анализ перераспределения тикетов" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </Border>

                        <!-- Сообщение, когда рекомендаций нет -->
                        <TextBlock x:Name="RebalanceEmptyText" Grid.Row="1"
                                   Text="Нагрузка распределена равномерно — перераспределение не требуется."
                                   Foreground="{DynamicResource Brush.TextSecondary}" FontSize="13"
                                   Padding="24,20" Visibility="Collapsed"/>

                        <!-- Таблица рекомендаций -->
                        <DataGrid x:Name="RebalanceGrid" Grid.Row="2" Style="{StaticResource GridBase}" Margin="8">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Тикет" Binding="{Binding TicketTitle}" Width="*"/>
                                <DataGridTextColumn Header="Приоритет" Binding="{Binding Priority}" Width="110" ElementStyle="{StaticResource CellCenter}"/>
                                <DataGridTextColumn Header="От кого" Binding="{Binding FromEmployeeName}" Width="160"/>
                                <DataGridTextColumn Header="Кому передать" Binding="{Binding ToEmployeeName}" Width="160"/>
                                <DataGridTemplateColumn Header="Действие" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Применить" Style="{StaticResource PrimaryButton}"
                                                    Height="30" FontSize="12" Margin="8,0"
                                                    Click="ApplyRebalance_Click"
                                                    Tag="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- ===================== БЛОК ПРОГНОЗА ===================== -->
                <TextBlock Text="Прогноз нагрузки" Style="{StaticResource SectionTitle}" Margin="0,32,0,16"/>

                <!-- Карточки прогноза -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource KpiCard}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="FcInflowText" Text="—" Style="{StaticResource KpiValue}"/>
                            <TextBlock Text="Прогноз притока (7 дн)" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource KpiCard}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="FcBacklogText" Text="—" Style="{StaticResource KpiValue}"/>
                            <TextBlock Text="Текущий backlog" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Style="{StaticResource KpiCard}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="FcRatioText" Text="—" Style="{StaticResource KpiValue}"/>
                            <TextBlock Text="Коэффициент нагрузки" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="6" Style="{StaticResource KpiCard}">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="FcRiskText" Text="—" Style="{StaticResource KpiValue}" FontSize="18"/>
                            <TextBlock Text="Риск срыва SLA" Style="{StaticResource KpiLabel}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- График прогноза -->
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Прогнозируемый поток новых тикетов по дням" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource Brush.TextPrimary}" Margin="0,0,0,16"/>
                        <lvc:CartesianChart Grid.Row="1" x:Name="ForecastChart" Series="{Binding ForecastSeries}" Height="280" LegendLocation="None">
                            <lvc:CartesianChart.AxisX>
                                <lvc:Axis Title="Дата" Labels="{Binding ForecastLabels}" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Step="1" StrokeThickness="0"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisX>
                            <lvc:CartesianChart.AxisY>
                                <lvc:Axis Title="Тикетов" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="11">
                                    <lvc:Axis.Separator>
                                        <lvc:Separator Stroke="{DynamicResource Brush.Border}"/>
                                    </lvc:Axis.Separator>
                                </lvc:Axis>
                            </lvc:CartesianChart.AxisY>
                        </lvc:CartesianChart>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
