<Window x:Class="КР_Ханников.Windows.CreateTicketWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание нового обращения"
        Height="720"
        Width="900"
        MinHeight="550"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI"
        Background="{DynamicResource Brush.Background}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Geometry x:Key="Icon.Close">M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z</Geometry>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Border}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" Opacity="0.06" ShadowDepth="2" Direction="270" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="FieldHint" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource Brush.Surface}" CornerRadius="10" BorderThickness="1" BorderBrush="{DynamicResource Brush.Border}">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="24,20" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" MouseLeftButtonDown="Header_MouseLeftButtonDown" Background="Transparent">
                <Grid>
                    <StackPanel>
                        <TextBlock Text="Новое обращение" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        <TextBlock Text="Просто опишите проблему, а ИИ автоматически настроит приоритет" FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,6,0,0"/>
                    </StackPanel>
                    <Button HorizontalAlignment="Right" VerticalAlignment="Top" Width="30" Height="30" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="Cancel_Click">
                        <Path Data="{StaticResource Icon.Close}" Fill="{DynamicResource Brush.TextSecondary}" Width="12" Height="12" Stretch="Uniform"/>
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="400"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="280" MinWidth="240"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="24">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <StackPanel Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Тема обращения" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text=" *" Foreground="{DynamicResource Brush.Danger}" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBox x:Name="TitleTextBox" Height="42" Padding="12,0" VerticalContentAlignment="Center" MaxLength="200" FontSize="14"/>
                                <TextBlock Text="Кратко опишите суть проблемы" Style="{StaticResource FieldHint}"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,20">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Описание проблемы" Style="{StaticResource FieldLabel}"/>
                                    <TextBlock Text=" *" Foreground="{DynamicResource Brush.Danger}" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBox x:Name="DescriptionTextBox" Height="Auto" MinHeight="120" MaxHeight="200" Padding="12" AcceptsReturn="True" TextWrapping="Wrap" FontSize="14" VerticalContentAlignment="Top"/>
                                <TextBlock Text="Подробно опишите проблему, шаги воспроизведения и ожидаемый результат" Style="{StaticResource FieldHint}" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,0,20">
                                <TextBlock Text="Желаемый срок выполнения" Style="{StaticResource FieldLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <DatePicker x:Name="DueDatePicker" Grid.Column="0" Height="42" FontSize="14" VerticalContentAlignment="Center"/>
                                    <TextBox x:Name="DueTimeBox" Grid.Column="2" Height="42" Text="18:00" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" MaxLength="5" FontSize="14"/>
                                </Grid>
                                <TextBlock Text="Оставьте пустым для автоматического расчёта на основе приоритета" Style="{StaticResource FieldHint}" TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Прикрепить файл" Style="{StaticResource FieldLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="{DynamicResource Brush.SurfaceAlt}" BorderThickness="1" BorderBrush="{DynamicResource Brush.Border}" CornerRadius="6" Padding="12,0" Height="42">
                                        <TextBlock x:Name="FileNameTextBlock" Text="Файл не выбран" VerticalAlignment="Center" Foreground="{DynamicResource Brush.TextMuted}" TextTrimming="CharacterEllipsis"/>
                                    </Border>

                                    <Button Grid.Column="2" Content="Обзор..." Style="{StaticResource SecondaryButton}" Click="AttachFile_Click" Padding="16,0" Height="42"/>
                                </Grid>
                                <TextBlock Text="Поддерживаются: PDF, PNG, JPG, DOC, DOCX, TXT (до 10 МБ)" Style="{StaticResource FieldHint}"/>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="20" VerticalAlignment="Top">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="💡" FontSize="18" Margin="0,0,10,0"/>
                            <TextBlock Text="Рекомендации" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                        </StackPanel>

                        <TextBlock Text="Как быстрее получить помощь:" Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" FontWeight="Medium" Margin="0,0,0,14"/>

                        <Border Background="{DynamicResource Brush.SurfaceAlt}" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="📝 Детализация" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                                <TextBlock Text="Опишите шаги, которые привели к ошибке." Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource Brush.SurfaceAlt}" CornerRadius="6" Padding="12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="📷 Скриншоты" Foreground="{DynamicResource Brush.TextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                                <TextBlock Text="Прикрепите скриншот ошибки или лог-файл." Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                            </StackPanel>
                        </Border>

                        <Border Background="#F9F5FF" BorderBrush="#E9D5FF" BorderThickness="1" CornerRadius="6" Padding="12">
                            <StackPanel>
                                <TextBlock Text="✨ Сила ИИ" Foreground="#6B21A8" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                                <TextBlock Text="Вам больше не нужно выбирать категорию! Нейросеть сама прочитает текст и назначит тикет нужному инженеру." Foreground="{DynamicResource Brush.TextSecondary}" FontSize="12" TextWrapping="Wrap" LineHeight="18"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="{DynamicResource Brush.Surface}" Padding="24,16" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,1,0,0" CornerRadius="0,0,10,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="*" Foreground="{DynamicResource Brush.Danger}" FontWeight="Bold" Margin="0,0,4,0"/>
                        <TextBlock Text="Обязательные поля" Foreground="{DynamicResource Brush.TextMuted}" FontSize="13"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Отмена" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" MinWidth="100" IsCancel="True"/>
                        <Button x:Name="SubmitButton" Content="Создать тикет" Style="{StaticResource PrimaryButton}" Click="Submit_Click" MinWidth="140" Margin="12,0,0,0" IsDefault="True"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>