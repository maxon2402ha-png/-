<Window x:Class="КР_Ханников.Windows.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему"
        Height="600"
        Width="900"
        MinHeight="550"
        MinWidth="750"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Border}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="24,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Background}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Storyboard x:Key="WindowLoadAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5"/>
        </Storyboard>

        <Storyboard x:Key="BrandPanelAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="-50" To="0" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6"/>
        </Storyboard>

        <Storyboard x:Key="LoginCardAnimation">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="50" To="0" Duration="0:0:0.6" BeginTime="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.6" BeginTime="0:0:0.2"/>
        </Storyboard>

    </Window.Resources>

    <Border Background="{DynamicResource Brush.Surface}" 
            CornerRadius="12" 
            BorderThickness="1" 
            BorderBrush="{DynamicResource Brush.Border}"
            MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="40" ShadowDepth="0" Opacity="0.25"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="11,0,0,11">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{DynamicResource Color.Primary}" Offset="0.0"/>
                        <GradientStop Color="{DynamicResource Color.PrimaryDark}" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid Margin="48" x:Name="BrandPanel">
                    <Grid.RenderTransform>
                        <TranslateTransform/>
                    </Grid.RenderTransform>

                    <StackPanel VerticalAlignment="Center">
                        <Border Width="72" Height="72" Background="White" CornerRadius="18" HorizontalAlignment="Left" Margin="0,0,0,28">
                            <TextBlock Text="🎫" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Text="Service Desk" Foreground="White" FontSize="36" FontWeight="Bold" LineHeight="42"/>
                        <TextBlock Text="Platform" Foreground="{DynamicResource Brush.PrimaryLight}" FontSize="36" FontWeight="Bold" Margin="0,0,0,24"/>

                        <TextBlock Text="Единая система управления обращениями и поддержки пользователей." 
                                   Foreground="{DynamicResource Brush.PrimaryLight}" 
                                   FontSize="16" 
                                   TextWrapping="Wrap" 
                                   Opacity="0.9"
                                   LineHeight="26"/>
                    </StackPanel>

                    <TextBlock Text="© 2025 КР Ханников" 
                               VerticalAlignment="Bottom" 
                               Foreground="White" 
                               Opacity="0.6" 
                               FontSize="12"/>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0" 
                        Content="✕" 
                        HorizontalAlignment="Right" 
                        Margin="16"
                        Width="32" Height="32"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="{DynamicResource Brush.TextSecondary}"
                        FontSize="16"
                        Cursor="Hand"
                        Click="Close_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.Danger}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Grid.Row="1" 
                            VerticalAlignment="Center" 
                            Margin="80,0"
                            x:Name="LoginContainer">
                    <StackPanel.RenderTransform>
                        <TranslateTransform/>
                    </StackPanel.RenderTransform>

                    <TextBlock Text="Добро пожаловать" 
                               FontSize="32" 
                               FontWeight="Bold" 
                               Foreground="{DynamicResource Brush.TextPrimary}" 
                               Margin="0,0,0,8"/>

                    <TextBlock Text="Войдите в свою учётную запись" 
                               FontSize="16" 
                               Foreground="{DynamicResource Brush.TextSecondary}" 
                               Margin="0,0,0,48"/>

                    <TextBlock Text="Логин" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="UsernameBox" 
                             Height="48" 
                             Padding="16,0" 
                             VerticalContentAlignment="Center"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource Brush.Border}"
                             Background="{DynamicResource Brush.Surface}"
                             Foreground="{DynamicResource Brush.TextPrimary}"
                             FontSize="15"
                             Margin="0,0,0,24">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock Text="Пароль" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="PasswordBox" 
                                 Height="48" 
                                 Padding="16,0" 
                                 VerticalContentAlignment="Center"
                                 BorderThickness="1"
                                 BorderBrush="{DynamicResource Brush.Border}"
                                 Background="{DynamicResource Brush.Surface}"
                                 Foreground="{DynamicResource Brush.TextPrimary}"
                                 FontSize="15"
                                 Margin="0,0,0,24"
                                 KeyDown="PasswordBox_KeyDown">
                        <PasswordBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </PasswordBox.Resources>
                    </PasswordBox>

                    <CheckBox x:Name="RememberMeCheck" 
                              Content="Запомнить меня" 
                              Margin="0,0,0,32"
                              Foreground="{DynamicResource Brush.TextSecondary}"
                              FontSize="14"
                              Cursor="Hand"/>

                    <Button x:Name="LoginButton"
                            Content="Войти" 
                            Click="Login_Click" 
                            IsDefault="True"
                            Style="{StaticResource PrimaryButton}"
                            Margin="0,0,0,16"/>

                    <Button Content="Создать аккаунт" 
                            Click="Register_Click" 
                            Style="{StaticResource SecondaryButton}"/>

                    <Grid x:Name="ErrorContainer" Margin="0,24,0,0" Visibility="Collapsed">
                        <Border Background="{DynamicResource Brush.Danger}" 
            Opacity="0.1" 
            CornerRadius="8"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12">
                            <TextBlock Text="⚠️" Margin="0,0,8,0" Foreground="{DynamicResource Brush.Danger}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="ErrorText"
                   Text="Неверный логин или пароль" 
                   Foreground="{DynamicResource Brush.Danger}" 
                   FontSize="13"
                   FontWeight="Medium"
                   VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>