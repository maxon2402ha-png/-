<UserControl x:Class="КР_Ханников.Windows.ClientHistoryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1200"
             FontFamily="Segoe UI"
             Background="{DynamicResource Brush.Background}">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" Opacity="0.04" ShadowDepth="2" Direction="270" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="KpiCard" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Padding" Value="16,14"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="{DynamicResource Brush.Border}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.TextSecondary}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.Background}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Brush.PrimaryLight}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="KpiLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="{DynamicResource Brush.Surface}" 
                Padding="24,20" 
                BorderBrush="{DynamicResource Brush.Border}" 
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="История и аналитика клиента" 
                           FontSize="22" 
                           FontWeight="Bold" 
                           Foreground="{DynamicResource Brush.TextPrimary}"/>
                <TextBlock Text="Просмотр обращений, статистика и экспорт данных" 
                           FontSize="13" 
                           Foreground="{DynamicResource Brush.TextSecondary}" 
                           Margin="0,6,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" 
                Style="{StaticResource Card}" 
                Margin="24,20,24,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Клиент" Style="{StaticResource FieldLabel}"/>
                    <ComboBox x:Name="ClientComboBox" 
                              Width="220" 
                              SelectionChanged="ClientComboBox_SelectionChanged" 
                              DisplayMemberPath="Name"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock Text="Период" Style="{StaticResource FieldLabel}"/>
                    <StackPanel Orientation="Horizontal">
                        <DatePicker x:Name="FromPicker" Width="125"/>
                        <TextBlock Text="—" 
                                   VerticalAlignment="Center" 
                                   Margin="10,0"
                                   Foreground="{DynamicResource Brush.TextMuted}"/>
                        <DatePicker x:Name="ToPicker" Width="125"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" 
                            Margin="20,0,0,0" 
                            VerticalAlignment="Bottom">
                    <CheckBox x:Name="ClosedOnlyCheckBox" 
                              Content="Только закрытые"
                              Height="36"
                              VerticalContentAlignment="Center"/>
                </StackPanel>

                <Button x:Name="LoadButton" 
                        Grid.Column="4"
                        Content="Применить" 
                        Click="LoadButton_Click" 
                        Style="{StaticResource PrimaryButton}"
                        VerticalAlignment="Bottom"
                        MinWidth="120"/>
            </Grid>
        </Border>

        <UniformGrid Grid.Row="2" 
                     Columns="5" 
                     Margin="24,16,24,0">
            <Border Style="{StaticResource KpiCard}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Всего обращений" Style="{StaticResource KpiLabel}"/>
                    <TextBlock x:Name="TotalCountText" 
                               Text="0" 
                               Style="{StaticResource KpiValue}"
                               Foreground="{DynamicResource Brush.TextPrimary}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCard}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="В работе" Style="{StaticResource KpiLabel}"/>
                    <TextBlock x:Name="OpenCountText" 
                               Text="0" 
                               Style="{StaticResource KpiValue}"
                               Foreground="{DynamicResource Brush.Status.InProgress}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCard}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="Закрыто" Style="{StaticResource KpiLabel}"/>
                    <TextBlock x:Name="ClosedCountText" 
                               Text="0" 
                               Style="{StaticResource KpiValue}"
                               Foreground="{DynamicResource Brush.Status.Closed}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCard}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="Ср. время решения" Style="{StaticResource KpiLabel}"/>
                    <TextBlock x:Name="AvgResolutionText" 
                               Text="—" 
                               Style="{StaticResource KpiValue}"
                               Foreground="{DynamicResource Brush.Accent}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource KpiCard}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Удовлетворенность" Style="{StaticResource KpiLabel}"/>
                    <TextBlock x:Name="AvgRatingText" 
                               Text="—" 
                               Style="{StaticResource KpiValue}"
                               Foreground="#7C3AED"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Grid.Row="3" 
                Style="{StaticResource Card}" 
                Margin="24,16" 
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" 
                        Background="{DynamicResource Brush.SurfaceAlt}" 
                        Padding="16,12"
                        CornerRadius="8,8,0,0"
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="Список обращений" 
                               FontWeight="SemiBold" 
                               FontSize="14"
                               Foreground="{DynamicResource Brush.TextPrimary}"/>
                </Border>

                <DataGrid x:Name="ClientTicketsGrid" 
                          Grid.Row="1"
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          HeadersVisibility="Column" 
                          GridLinesVisibility="Horizontal" 
                          HorizontalGridLinesBrush="{DynamicResource Brush.Border}" 
                          VerticalGridLinesBrush="Transparent"
                          Background="Transparent" 
                          BorderThickness="0" 
                          RowHeaderWidth="0"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          MouseDoubleClick="ClientTicketsGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Тема" Binding="{Binding Title}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontWeight" Value="Medium"/>
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Категория" Binding="{Binding Category}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Создано" 
                                            Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy HH:mm}" 
                                            Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="Закрыто" 
                                            Binding="{Binding ClosedAt, StringFormat=dd.MM.yyyy HH:mm, TargetNullValue=—}" 
                                            Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="4" 
                Background="{DynamicResource Brush.Surface}" 
                Padding="24,16" 
                BorderBrush="{DynamicResource Brush.Border}" 
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Дважды кликните по строке для просмотра деталей"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           FontSize="12"/>

                <StackPanel Grid.Column="1" 
                            Orientation="Horizontal">
                    <TextBlock Text="Экспорт:" 
                               VerticalAlignment="Center" 
                               Margin="0,0,12,0" 
                               Foreground="{DynamicResource Brush.TextSecondary}"
                               FontSize="13"/>
                    <Button x:Name="ExportClientCsvButton" 
                            Content="CSV" 
                            Click="ExportClientCsvButton_Click" 
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="70"/>
                    <Button x:Name="ExportClientPdfButton" 
                            Content="PDF" 
                            Click="ExportClientPdfButton_Click" 
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="70"
                            Margin="8,0,0,0"/>
                    <Button Content="Закрыть" 
                            Click="Close_Click" 
                            Style="{StaticResource SecondaryButton}"
                            MinWidth="90"
                            Margin="16,0,0,0"
                            IsCancel="True"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>