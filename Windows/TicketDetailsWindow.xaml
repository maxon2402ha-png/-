<Window x:Class="КР_Ханников.Windows.TicketDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:КР_Ханников.Converters"
        Title="Детали тикета" Height="800" Width="1050" MinHeight="650" MinWidth="850"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI" Background="{DynamicResource Brush.Background}">

    <Window.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:NullToVisibilityConverter x:Key="NullToVis"/>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:RoleToColorConverter x:Key="RoleToColor"/>

        <Geometry x:Key="Icon.Ticket">M20 12l-1.41-1.41L13 16.17V4h-2v12.17l-5.58-5.59L4 12l8 8 8-8z</Geometry>
        <Geometry x:Key="Icon.Clock">M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z</Geometry>
        <Geometry x:Key="Icon.User">M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z</Geometry>
        <Geometry x:Key="Icon.Attachment">M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5V5c0-2.21-1.79-4-4-4S7 2.79 7 5v12.5c0 3.04 2.46 5.5 5.5 5.5s5.5-2.46 5.5-5.5V6h-1.5z</Geometry>
        <Geometry x:Key="Icon.Send">M2.01 21L23 12 2.01 3 2 10l15 2-15 2z</Geometry>
        <Geometry x:Key="Icon.Edit">M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z</Geometry>
        <Geometry x:Key="Icon.Lock">M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z</Geometry>

        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.PrimaryDark}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Border}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="#10B981"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Brush.Surface}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" Opacity="0.04" ShadowDepth="2" Direction="270" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource Brush.Border}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="Value" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        </Style>

        <Storyboard x:Key="WindowFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.15"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource WindowFadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}" Padding="24,16" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource Brush.PrimaryLight}" CornerRadius="8" Width="40" Height="40" Margin="0,0,16,0">
                        <Path Data="{StaticResource Icon.Ticket}" Fill="{DynamicResource Brush.Primary}" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TicketIdHeader" Text="#123" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                            <Border x:Name="StatusBadge" Margin="12,0,0,0" CornerRadius="4" Padding="8,2" VerticalAlignment="Center" Background="#2563EB">
                                <TextBlock x:Name="StatusText" Text="Open" Foreground="White" FontSize="11" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock x:Name="TicketTitleHeader" Text="Тема тикета..." FontSize="13" Foreground="{DynamicResource Brush.TextSecondary}" TextTrimming="CharacterEllipsis" MaxWidth="600"/>
                    </StackPanel>
                </StackPanel>

                <Border x:Name="TimerBorder" Grid.Column="2" Background="#F3F4F6" CornerRadius="8" Padding="12,8" VerticalAlignment="Center" Margin="16,0">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource Icon.Clock}" Fill="{Binding Foreground, ElementName=TimerText}" Width="16" Height="16" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TimerText" Text="00:00:00" FontSize="16" FontWeight="Bold" Foreground="#374151" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Описание" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,8"/>
                        <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" FontSize="14" Foreground="{DynamicResource Brush.TextPrimary}"/>

                        <Border x:Name="AttachmentPanel" Background="{DynamicResource Brush.SurfaceAlt}" CornerRadius="6" Padding="12" Margin="0,16,0,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource Icon.Attachment}" Fill="{DynamicResource Brush.TextSecondary}" Width="16" Margin="0,0,10,0"/>
                                <TextBlock x:Name="FileNameText" Text="file.txt" VerticalAlignment="Center" FontWeight="Medium" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                <Button Content="Скачать" Style="{StaticResource CompactButton}" Margin="12,0,0,0" Click="OpenAttachment_Click"/>
                            </StackPanel>
                        </Border>

                        <Border x:Name="SolutionPanel" Background="#ECFDF5" BorderBrush="#10B981" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,16,0,0" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="РЕШЕНИЕ" Foreground="#059669" FontWeight="Bold" FontSize="11" Margin="0,0,0,4"/>
                                <TextBlock x:Name="SolutionText" Text="..." TextWrapping="Wrap" Foreground="#064E3B"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" CornerRadius="8,8,0,0" Margin="0,16,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="0,0,0,1" Padding="16,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="История и комментарии" FontWeight="SemiBold" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                <Border x:Name="CommentsCountBadge" Background="{DynamicResource Brush.SurfaceAlt}" CornerRadius="10" Padding="8,2" Margin="8,0,0,0">
                                    <TextBlock x:Name="CommentsCountText" Text="0" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource Brush.TextSecondary}"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="1" x:Name="CommentsScrollViewer" VerticalScrollBarVisibility="Auto" Padding="16">
                            <ItemsControl x:Name="CommentsList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0" Width="32" Height="32" Margin="0,0,8,0" VerticalAlignment="Top">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMe}" Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Ellipse Stroke="{DynamicResource Brush.Border}" StrokeThickness="1" Fill="{Binding Role, Converter={StaticResource RoleToColor}, ConverterParameter=bg}"/>
                                                <Path Data="{StaticResource Icon.User}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="White"/>
                                                <Ellipse>
                                                    <Ellipse.Fill>
                                                        <ImageBrush ImageSource="{Binding AvatarPath, Converter={StaticResource PathToImageConverter}}" Stretch="UniformToFill"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                            </Grid>

                                            <Border Grid.Column="1" MaxWidth="600" Padding="12,10" CornerRadius="12">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="VerticalAlignment" Value="Top"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMe}" Value="True">
                                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                                <Setter Property="Background" Value="{DynamicResource Brush.PrimaryLight}"/>
                                                                <Setter Property="CornerRadius" Value="12,12,0,12"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsMe}" Value="False">
                                                                <Setter Property="HorizontalAlignment" Value="Left"/>
                                                                <Setter Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                                                                <Setter Property="CornerRadius" Value="12,12,12,0"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsInternal}" Value="True">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                                <Setter Property="BorderBrush" Value="#F59E0B"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <Path Data="{StaticResource Icon.Lock}" Fill="#D97706" Width="10" Height="10" Margin="0,0,6,0" Visibility="{Binding IsInternal, Converter={StaticResource BoolToVis}}"/>
                                                        <TextBlock Text="{Binding AuthorName}" FontWeight="Bold" FontSize="12" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                                        <TextBlock Text="{Binding CreatedAt, StringFormat=HH:mm}" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}" Margin="8,0,0,0" VerticalAlignment="Bottom"/>
                                                    </StackPanel>

                                                    <TextBlock Text="🔒 Внутренний комментарий" FontSize="10" Foreground="#D97706" Margin="0,0,0,2" Visibility="{Binding IsInternal, Converter={StaticResource BoolToVis}}"/>
                                                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" FontSize="13" Foreground="{DynamicResource Brush.TextPrimary}"/>
                                                </StackPanel>
                                            </Border>

                                            <Grid Grid.Column="2" Width="32" Height="32" Margin="8,0,0,0" VerticalAlignment="Top">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsMe}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Ellipse Stroke="{DynamicResource Brush.Border}" StrokeThickness="1" Fill="{Binding Role, Converter={StaticResource RoleToColor}, ConverterParameter=bg}"/>
                                                <Path Data="{StaticResource Icon.User}" Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" Fill="White"/>
                                                <Ellipse>
                                                    <Ellipse.Fill>
                                                        <ImageBrush ImageSource="{Binding AvatarPath, Converter={StaticResource PathToImageConverter}}" Stretch="UniformToFill"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Background="{DynamicResource Brush.Surface}" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8" Padding="12" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <CheckBox x:Name="InternalCheck" Content="Внутренний комментарий (скрыт от клиента)" FontSize="11" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,8" Visibility="Collapsed"/>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="CommentBox" MinHeight="40" MaxHeight="100" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Padding="8" FontSize="13" BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1" Background="Transparent" Foreground="{DynamicResource Brush.TextPrimary}"/>
                            <Button Grid.Column="1" x:Name="SendCommentButton" Width="47" Height="47" Margin="8,0,0,0" Style="{StaticResource BtnPrimary}" Click="SendComment_Click">
                                <Path Data="{StaticResource Icon.Send}" Fill="White" Width="16" Stretch="Uniform"/>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <Expander Grid.Row="3" Header="История изменений" Foreground="{DynamicResource Brush.TextSecondary}">
                    <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Height="150" Background="{DynamicResource Brush.Surface}" BorderThickness="1" BorderBrush="{DynamicResource Brush.Border}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Время" Binding="{Binding Timestamp, StringFormat=dd.MM HH:mm}" Width="100"/>
                            <DataGridTextColumn Header="Действие" Binding="{Binding Action}" Width="120"/>
                            <DataGridTextColumn Header="Детали" Binding="{Binding Details}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Expander>
            </Grid>

            <StackPanel Grid.Column="2">
                <Border x:Name="OperatorControlsPanel" Style="{StaticResource Card}" Margin="0,0,0,16" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="УПРАВЛЕНИЕ" Style="{StaticResource Label}"/>

                        <TextBlock Text="Текущий статус:" FontSize="12" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,8,0,4"/>
                        <ComboBox x:Name="StatusCombo" Height="30" Margin="0,0,0,12" SelectionChanged="StatusCombo_SelectionChanged"/>

                        <TextBlock Text="Приоритет:" FontSize="12" Foreground="{DynamicResource Brush.TextSecondary}" Margin="0,0,0,4"/>
                        <ComboBox x:Name="PriorityCombo" Height="30" Margin="0,0,0,12" SelectionChanged="PriorityCombo_SelectionChanged"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>

                        <TextBlock Text="SLA / ДЕДЛАЙН" Style="{StaticResource Label}"/>
                        <TextBlock x:Name="SlaStatusText" Text="Осталось: ..." Style="{StaticResource Value}" Margin="0,0,0,4"/>
                        <ProgressBar x:Name="SlaProgressBar" Height="6" Margin="0,0,0,16" BorderThickness="0" Background="{DynamicResource Brush.Border}" Foreground="{DynamicResource Brush.Primary}">
                            <ProgressBar.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="3"/>
                                </Style>
                            </ProgressBar.Resources>
                        </ProgressBar>

                        <TextBlock Text="КЛИЕНТ" Style="{StaticResource Label}"/>
                        <TextBlock x:Name="ClientNameText" Text="—" Style="{StaticResource Value}" Margin="0,0,0,4"/>
                        <TextBlock x:Name="ClientEmailText" Text="—" FontSize="12" Foreground="{DynamicResource Brush.TextMuted}" Margin="0,0,0,16"/>

                        <TextBlock Text="ИСПОЛНИТЕЛЬ" Style="{StaticResource Label}"/>
                        <TextBlock x:Name="AssigneeText" Text="—" Style="{StaticResource Value}" Margin="0,0,0,16"/>

                        <TextBlock Text="КАТЕГОРИЯ" Style="{StaticResource Label}"/>
                        <TextBlock x:Name="CategoryText" Text="—" Style="{StaticResource Value}" Margin="0,0,0,16"/>

                        <TextBlock Text="ПРИОРИТЕТ" Style="{StaticResource Label}"/>
                        <TextBlock x:Name="PriorityText" Text="—" Style="{StaticResource Value}"/>
                    </StackPanel>
                </Border>

                <StackPanel Margin="0,16,0,0">
                    <Button x:Name="CloseTicketButton" Click="CloseTicket_Click" Style="{StaticResource SuccessButton}" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                        <TextBlock Text="✓ Решить тикет"/>
                    </Button>

                    <Button x:Name="EditButton" Click="Edit_Click" Style="{StaticResource BtnSecondary}" Margin="0,0,0,8" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource Icon.Edit}" Fill="{DynamicResource Brush.TextPrimary}" Width="14" Height="14" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="Редактировать"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="RateButton" Content="⭐ Оценить работу" Style="{StaticResource BtnSecondary}" Visibility="Collapsed" Click="Rate_Click" HorizontalAlignment="Stretch" Margin="0,0,0,8"/>

                    <Button Content="Закрыть окно" Click="CloseWindow_Click" Style="{StaticResource BtnSecondary}" Margin="0,16,0,0" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>